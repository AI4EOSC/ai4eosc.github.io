---
import data from '../../data/testimonials.yml';
import SectionHeader from '../ui/SectionHeader.astro';

const avatarPalette = [
  { bg: 'var(--color-primary-100)',   color: 'var(--color-primary-700)'   },
  { bg: 'var(--color-secondary-100)', color: 'var(--color-secondary-700)' },
  { bg: '#dbeafe',                    color: '#1d4ed8'                    },
];
---

<section>
  <div class="section-label">
    <div class="container">Testimonials</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader title="What researchers say" subtitle="Feedback from scientists and developers building on the AI4EOSC platform." />
      <div class="grid">
        {data.items.map((item, i) => (
          <div class="item reveal" style={`transition-delay: ${i * 80}ms`}>
            <svg class="quote-svg" width="36" height="28" viewBox="0 0 36 28" fill="none" aria-hidden="true">
              <path d="M0 28V16.8C0 7.6 5.2 2 15.6 0L17.2 3C11.6 4.6 8.8 7.8 8.4 12.4H14V28H0ZM19.6 28V16.8C19.6 7.6 24.8 2 35.2 0L36 3C30.4 4.6 27.6 7.8 27.2 12.4H32.8V28H19.6Z" fill="currentColor"/>
            </svg>
            <p class="quote">{item.quote}</p>
            <div class="author">
              <div class="avatar" style={`background: ${avatarPalette[i % 3].bg}; color: ${avatarPalette[i % 3].color};`}>{item.initials}</div>
              <div class="author-info">
                <span class="name">{item.name}</span>
                <span class="role">{item.role}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 24px;
    border-top: 1px solid var(--card-border);
  }

  .item {
    padding: 28px 32px 8px 0;
    border-right: 1px solid var(--card-border);
    display: flex;
    flex-direction: column;
  }

  .item:last-child {
    border-right: none;
    padding-right: 0;
  }

  .item + .item {
    padding-left: 32px;
  }

  .quote-svg {
    color: var(--color-primary-200);
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .quote {
    margin: 0 0 24px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-neutral-600);
    flex: 1;
  }

  .author {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 28px;
  }

  .avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .name {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-neutral-800);
    line-height: 1.2;
  }

  .role {
    font-size: 12px;
    color: var(--color-neutral-400);
    line-height: 1.2;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
      border-top: none;
    }

    .item {
      padding: 24px 0;
      border-right: none;
      border-top: 1px solid var(--card-border);
    }

    .item + .item {
      padding-left: 0;
    }
  }
</style>
