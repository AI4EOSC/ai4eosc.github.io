---
import SectionHeader from '../SectionHeader.astro';

const items = [
  { tag: 'Developer',   title: 'Deploy your models on EOSC',   description: 'Use our open-source platform to train, serve and publish AI models with EOSC-native auth.',                        linkLabel: 'Explore products →',    linkHref: '/products' },
  { tag: 'Researcher',  title: 'Find AI tools for your domain', description: 'Access ready-to-use AI models and computing resources tailored to your scientific field.',                          linkLabel: 'Explore communities →', linkHref: '/ecosystem/communities' },
  { tag: 'Institution', title: 'Build your own gateway',        description: 'Deploy a customised instance of the platform for your project and join the ecosystem.',                              linkLabel: 'Join the ecosystem →',  linkHref: '/ecosystem/gateways' },
];
---

<section>
  <div class="section-label">
    <div class="container">Who is it for</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader title="Find your path" subtitle="Whether you're a researcher looking for tools, a developer deploying models, or an institution building a gateway — AI4EOSC has a path for you." />
      <div class="grid">
        {items.map((item, i) => (
          <div class="item reveal" style={`transition-delay: ${i * 80}ms`}>
            <span class="role">{item.tag}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a class="link" href={item.linkHref}>{item.linkLabel}</a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 24px;
    border-top: 1px solid var(--card-border);
  }

  .item {
    padding: 28px 32px 8px 0;
    border-right: 1px solid var(--card-border);
    display: flex;
    flex-direction: column;
  }

  .item:last-child {
    border-right: none;
    padding-right: 0;
  }

  .item + .item {
    padding-left: 32px;
  }

  .role {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-neutral-400);
    margin-bottom: 14px;
  }

  h3 {
    margin: 0 0 12px;
    font-family: var(--font-headings);
    font-size: 20px;
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--color-neutral-900);
    line-height: 1.2;
  }

  p {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-neutral-500);
    flex: 1;
  }

  .link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary-700);
    text-decoration: none;
    margin-top: auto;
  }

  .link:hover {
    color: var(--color-primary-600);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      border-top: none;
    }

    .item {
      padding: 24px 0;
      border-right: none;
      border-top: 1px solid var(--card-border);
    }

    .item + .item {
      padding-left: 0;
    }
  }
</style>
