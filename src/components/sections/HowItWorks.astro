---
import howItWorks from '../../data/how-it-works.yml';

const gradients: Record<string, string> = {
  primary:   'var(--gradient-primary)',
  secondary: 'var(--gradient-pink)',
  'eu-blue': 'var(--gradient-eu-blue)',
};
---

<section>
  <div class="section-label">
    <div class="container">{howItWorks.label}</div>
  </div>
  <div class="container">
    <div class="grid">
      {howItWorks.items.map((item) => (
        <article class="card glass" key={item.title}>
          <div class="header" style={`background: ${gradients[item.theme]}`}>
            <span class="circle circle--lg" aria-hidden="true"></span>
            <span class="circle circle--md" aria-hidden="true"></span>
            <span class="circle circle--sm" aria-hidden="true"></span>
          </div>
          <div class="body">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 28px;
  }

  .card {
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .header {
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .header::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.22) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  .header::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 70% at 15% 20%, rgba(255, 255, 255, 0.10) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 85% 85%, rgba(0, 0, 0, 0.15) 0%, transparent 55%);
    pointer-events: none;
    z-index: 0;
  }

  .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.26),
      0 0 30px rgba(255, 255, 255, 0.14),
      0 0 60px rgba(255, 255, 255, 0.06),
      inset 0 0 12px rgba(255, 255, 255, 0.05);
    animation: pulsing 5s ease-in-out infinite;
    z-index: 0;
  }

  .circle--lg { width: 85%; animation-delay: 2s; }
  .circle--md { width: 58%; animation-delay: 1s; }
  .circle--sm { width: 35%; animation-delay: 0s; }

  .body {
    padding: 20px 22px 26px;
  }

  h3 {
    margin: 0 0 8px;
    font-family: var(--font-headings);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-neutral-900);
  }

  p {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-neutral-500);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
