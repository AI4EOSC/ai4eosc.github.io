---
import SectionHeader from '../SectionHeader.astro';

const items = [
  {
    step: '01',
    title: 'Products',
    iconId: 'products',
    description: 'Open-source software for training, serving and cataloguing AI models — built for EOSC. Includes DEEPaaS API, OSCAR, CVAT and the AI4EOSC Agents framework.',
  },
  {
    step: '02',
    title: 'Ecosystem',
    iconId: 'ecosystem',
    description: 'A network of EU-funded projects and scientific communities that extend and use the platform — from EOSC-ARENA and FLUID-AI to domain-specific research groups across Europe.',
  },
  {
    step: '03',
    title: 'Gateways',
    iconId: 'gateways',
    description: 'Domain-specific deployments giving researchers direct access to AI tools in their field — iMagine for marine science, ClimAI for climate research, and more.',
  },
];

const icons: Record<string, string> = {
  products:  `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`,
  ecosystem: `<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>`,
  gateways:  `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
};
---

<section>
  <div class="section-label">
    <div class="container">How it works</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title="How AI4EOSC works"
        subtitle="Three layers working together to bring open AI infrastructure to European research."
      />
      <div class="grid">
        {items.map((item, i) => (
          <div class="item reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="item-top">
              <div class="icon-wrap">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={icons[item.iconId]}
                />
              </div>
              <span class="step-num">{item.step}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 32px;
    border-top: 1px solid var(--card-border);
  }

  .item {
    padding: 32px 36px 36px 0;
    border-right: 1px solid var(--card-border);
    position: relative;
  }

  .item:last-child { border-right: none; padding-right: 0; }
  .item + .item    { padding-left: 36px; }

  /* Arrow badge on each divider */
  .item:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -13px;
    top: 46px;
    width: 26px;
    height: 26px;
    text-align: center;
    line-height: 24px;
    font-size: 11px;
    color: var(--color-primary-400);
    background: white;
    border-radius: 50%;
    border: 1px solid var(--color-primary-100);
    z-index: 2;
  }

  /* ── Item head: icon left, big step number right ─────────────── */
  .item-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 22px;
  }

  .icon-wrap {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-100);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary-600);
    flex-shrink: 0;
  }

  .step-num {
    font-family: var(--font-headings);
    font-size: 52px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-primary-100);
    user-select: none;
  }

  /* ── Text ────────────────────────────────────────────────────── */
  h3 {
    margin: 0 0 12px;
    font-family: var(--font-headings);
    font-size: 22px;
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--color-neutral-900);
    line-height: 1.2;
  }

  p {
    margin: 0;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-neutral-500);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      border-top: none;
    }

    .item {
      border-right: none;
      border-top: 1px solid var(--card-border);
      padding: 24px 0 28px;
    }

    .item + .item { padding-left: 0; }

    .item:not(:last-child)::after { display: none; }
  }
</style>
