---
import SectionHeader from '../SectionHeader.astro';

const label = 'How it works';
const title = 'How AI4EOSC works';
const description = 'Three layers working together to bring open AI infrastructure to European research.';

const items = [
  { title: 'Products',   theme: 'eu-blue',   iconId: 'products',  description: 'Open-source software for training, serving and cataloguing AI models — built for EOSC.' },
  { title: 'Ecosystem',  theme: 'secondary', iconId: 'ecosystem', description: 'EU-funded projects and scientific communities extending and using the platform.' },
  { title: 'Gateways',   theme: 'primary',   iconId: 'gateways',  description: 'Domain-specific deployments giving researchers direct access to AI tools in their field.' },
];

const gradients: Record<string, string> = {
  'eu-blue': 'var(--gradient-eu-blue)',
  secondary: 'var(--gradient-pink)',
  primary:   'var(--gradient-primary)',
};

const icons: Record<string, string> = {
  products:  `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`,
  ecosystem: `<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>`,
  gateways:  `<path d="M3 21V9a9 9 0 0 1 18 0v12"/><path d="M3 21h18"/><path d="M9 21V12a3 3 0 0 1 6 0v9"/>`,
};
---

<section>
  <div class="section-label">
    <div class="container">{label}</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader title={title} subtitle={description} />
      <div class="grid">
        {items.map((item) => (
          <article class="card glass" key={item.title}>
            <div class="header" style={`background: ${gradients[item.theme]}`}>
              <span class="circle circle--lg" aria-hidden="true"></span>
              <span class="circle circle--md" aria-hidden="true"></span>
              <span class="circle circle--sm" aria-hidden="true"></span>
              <svg
                class="icon"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={icons[item.iconId]}
              />
            </div>
            <div class="body">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-bottom: 28px;
  }

  .card {
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .header {
    height: 110px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .header::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 70% at 15% 20%, rgba(255, 255, 255, 0.10) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 85% 85%, rgba(0, 0, 0, 0.15) 0%, transparent 55%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Circles ── */
  .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.26),
      0 0 30px rgba(255, 255, 255, 0.14),
      0 0 60px rgba(255, 255, 255, 0.06),
      inset 0 0 12px rgba(255, 255, 255, 0.05);
    animation: pulsing 5s ease-in-out infinite;
    z-index: 0;
  }

  .circle--lg { width: 85%; animation-delay: 2s; }
  .circle--md { width: 58%; animation-delay: 1s; }
  .circle--sm { width: 35%; animation-delay: 0s; }

  .icon {
    position: relative;
    z-index: 2;
    opacity: 0.92;
    filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.35));
  }

  /* ── Body ── */
  .body {
    padding: 20px 22px 26px;
  }

  h3 {
    margin: 0 0 8px;
    font-family: var(--font-headings);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-neutral-900);
  }

  p {
    margin: 0;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-neutral-500);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
