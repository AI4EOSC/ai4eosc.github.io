---
import SectionHeader from '../SectionHeader.astro';

const items = [
  { title: 'Products',   step: '01', iconId: 'products',  description: 'Open-source software for training, serving and cataloguing AI models — built for EOSC.' },
  { title: 'Ecosystem',  step: '02', iconId: 'ecosystem', description: 'EU-funded projects and scientific communities extending and using the platform.' },
  { title: 'Gateways',   step: '03', iconId: 'gateways',  description: 'Domain-specific deployments giving researchers direct access to AI tools in their field.' },
];

const icons: Record<string, string> = {
  products:  `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`,
  ecosystem: `<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>`,
  gateways:  `<path d="M3 21V9a9 9 0 0 1 18 0v12"/><path d="M3 21h18"/><path d="M9 21V12a3 3 0 0 1 6 0v9"/>`,
};
---

<section>
  <div class="section-label">
    <div class="container">How it works</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader title="How AI4EOSC works" subtitle="Three layers working together to bring open AI infrastructure to European research." />
      <div class="grid">
        {items.map((item, i) => (
          <div class="item reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="item-top">
              <svg
                class="icon"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={icons[item.iconId]}
              />
              <span class="step">{item.step}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 24px;
    border-top: 1px solid var(--card-border);
  }

  .item {
    padding: 28px 32px 4px 0;
    border-right: 1px solid var(--card-border);
  }

  .item:last-child {
    border-right: none;
    padding-right: 0;
  }

  .item + .item {
    padding-left: 32px;
  }

  .item-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .icon {
    color: var(--color-neutral-400);
  }

  .step {
    font-family: var(--font-headings);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-primary-200);
  }

  h3 {
    margin: 0 0 10px;
    font-family: var(--font-headings);
    font-size: 18px;
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--color-neutral-900);
  }

  p {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-neutral-500);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      border-top: none;
    }

    .item {
      padding: 0 0 24px;
      border-right: none;
      border-top: 1px solid var(--card-border);
      padding-top: 24px;
    }

    .item + .item {
      padding-left: 0;
    }
  }
</style>
