---
import data from '../../data/projects.yml';
import SectionHeader from '../SectionHeader.astro';

const MAX_ITEMS = 5;
---

<section>
  <div class="section-label">
    <div class="container">{data.label}</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title={data.title}
        subtitle={data.description}
        actionLabel={data.action.label}
        actionHref={data.action.href}
      />
      <div class="grid">
        {data.items.slice(0, MAX_ITEMS).map((item) => (
          <article class="card glass" key={item.title}>
            <div class="row">
              <span class="tag">{item.tag}</span>
              <span class={`status ${item.status.toLowerCase()}`}>{item.status}</span>
            </div>
            <h4>{item.title}</h4>
            <p>{item.description}</p>
          </article>
        ))}
        <a class="card more" href={data.more.href}>{data.more.label}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .card {
    border-radius: var(--radius-sm);
    padding: 14px 16px;
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-neutral-600);
    background: var(--color-neutral-200);
    border-radius: 999px;
    padding: 2px 9px;
  }

  .status {
    font-size: 11px;
    font-weight: 600;
    border-radius: 999px;
    padding: 2px 8px;
  }

  .status.active {
    color: var(--color-primary-700);
    background: var(--color-primary-100);
  }

  .status.new {
    color: var(--color-secondary-700);
    background: var(--color-secondary-100);
  }

  h4 {
    margin: 0 0 4px;
    font-size: 14px;
    font-weight: 600;
  }

  p {
    margin: 0;
    font-size: 13px;
    color: var(--color-neutral-400);
  }

  .more {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0.5px dashed var(--color-neutral-300);
    color: var(--color-neutral-400);
    text-decoration: none;
    min-height: 80px;
    font-size: 13px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
