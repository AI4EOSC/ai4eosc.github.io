---
import data from '../../data/gateways.yml';
---

<section class="wrap">
  <div class="section-label">
    <div class="container">{data.label}</div>
  </div>
  <div class="container">
    <div class="hero">
      <div class="deco one"></div>
      <div class="deco two"></div>
      <h2>{data.hero.title}</h2>
      <p>{data.hero.description}</p>
      <a class="button-pill ghost" href={data.hero.buttonHref}>{data.hero.buttonLabel}</a>
    </div>
    <div class="grid">
      {data.items.map((item) => (
        <article class="card" key={item.title}>
          <div class="row">
            <span class="tag">{item.tag}</span>
            <span class={`status ${item.status.toLowerCase()}`}>{item.status}</span>
          </div>
          <h4>{item.title}</h4>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .wrap {
    padding-bottom: 20px;
  }

  .hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: linear-gradient(140deg, var(--color-primary-700), var(--color-primary-500));
    padding: 36px 40px;
    color: #ffffff;
    margin-bottom: 12px;
  }

  h2 {
    margin: 0 0 10px;
    font-family: var(--font-headings);
    font-size: 40px;
    font-weight: 500;
  }

  p {
    margin: 0 0 20px;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.72);
    max-width: 380px;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .card {
    background: #ffffff;
    border: 0.5px solid color-mix(in oklch, var(--color-primary-200) 60%, #ffffff 40%);
    border-radius: var(--radius-md);
    padding: 16px;
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.04);
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-primary-700);
    background: var(--color-primary-100);
    border-radius: 999px;
    padding: 2px 9px;
  }

  .status {
    font-size: 11px;
    font-weight: 600;
    border-radius: 999px;
    padding: 2px 8px;
  }

  .status.active {
    color: var(--color-primary-700);
    background: var(--color-primary-100);
  }

  .status.new {
    color: var(--color-secondary-700);
    background: var(--color-secondary-100);
  }

  h4 {
    margin: 0 0 4px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-neutral-900);
  }

  .card p {
    margin: 0;
    font-size: 12px;
    color: var(--color-neutral-400);
  }

  .deco {
    position: absolute;
    border-radius: 50%;
    border: 1px dashed rgba(255, 255, 255, 0.12);
  }

  .deco.one {
    width: 220px;
    height: 220px;
    right: -20px;
    top: -20px;
  }

  .deco.two {
    width: 160px;
    height: 160px;
    right: 70px;
    bottom: -50px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
