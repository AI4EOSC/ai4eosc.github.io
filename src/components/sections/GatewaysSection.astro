---
import data from '../../data/gateways.yml';
---

<section class="wrap">
  <div class="section-label">
    <div class="container">{data.label}</div>
  </div>
  <div class="container">
    <div class="hero">
      <div class="hero-content">
        <h2>{data.hero.title}</h2>
        <p>{data.hero.description}</p>
        <a class="button-pill ghost" href={data.hero.buttonHref}>{data.hero.buttonLabel}</a>
      </div>
      <div class="hero-circles" aria-hidden="true">
        <span class="circle circle--lg"></span>
        <span class="circle circle--md"></span>
        <span class="circle circle--sm"></span>
      </div>
    </div>
    <div class="grid">
      {data.items.map((item) => (
        <article class="card glass primary" key={item.title}>
          <div class="row">
            <span class="tag">{item.tag}</span>
            <span class={`status ${item.status.toLowerCase()}`}>{item.status}</span>
          </div>
          <h4>{item.title}</h4>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .wrap {
    padding-bottom: 20px;
  }

  .hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: linear-gradient(140deg, var(--color-primary-700), var(--color-primary-500));
    padding: 36px 40px;
    color: #ffffff;
    margin-bottom: 12px;
  }

  h2 {
    margin: 0 0 10px;
    font-family: var(--font-headings);
    font-size: 46px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  p {
    margin: 0 0 20px;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.72);
    max-width: 380px;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .card {
    border-radius: var(--radius-md);
    padding: 16px;
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-primary-700);
    background: var(--color-primary-100);
    border-radius: 999px;
    padding: 2px 9px;
  }

  .status {
    font-size: 11px;
    font-weight: 600;
    border-radius: 999px;
    padding: 2px 8px;
  }

  .status.active {
    color: var(--color-primary-700);
    background: var(--color-primary-100);
  }

  .status.new {
    color: var(--color-secondary-700);
    background: var(--color-secondary-100);
  }

  h4 {
    margin: 0 0 4px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-neutral-900);
  }

  .card p {
    margin: 0;
    font-size: 13px;
    color: var(--color-neutral-400);
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  @keyframes pulsing {
    0%, 100% { scale: 1; }
    50%       { scale: 1.05; }
  }

  .hero-circles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px dashed rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.04);
    animation: pulsing 5s ease-in-out infinite;
    transition: scale 2s ease;
  }

  .circle--lg { width: 90%; animation-delay: 2s; }
  .circle--md { width: 64%; animation-delay: 1s; }
  .circle--sm { width: 40%; animation-delay: 0s; }

  .hero:hover .circle {
    scale: 1.10;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
