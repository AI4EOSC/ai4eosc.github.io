---
import data from '../../data/open-source.yml';
---

<section class="os-wrap">
  <div class="container">
    <div class="banner">
      <div class="left">
        <span class="icon" aria-hidden="true">{data.icon}</span>
        <div>
          <h4>{data.title}</h4>
          <p>{data.description}</p>
        </div>
      </div>
      <a class="button-pill primary" href={data.button.href}>{data.button.label}</a>
    </div>
  </div>
</section>

<style>
  .os-wrap {
    padding: 8px 0 20px;
  }

  .banner {
    background: var(--color-neutral-900);
    border-radius: 16px;
    padding: 16px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    color: #ffffff;
  }

  .left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .icon {
    font-size: 20px;
  }

  h4 {
    margin: 0 0 2px;
    font-size: 15px;
    font-weight: 600;
  }

  p {
    margin: 0;
    font-size: 13px;
    color: var(--color-neutral-400);
  }

  @media (max-width: 720px) {
    .banner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
