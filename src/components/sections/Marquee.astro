---
import partnersData from '../../data/partners.yml';

const logoUrls = import.meta.glob<string>(
  '../../assets/logos/*',
  { eager: true, query: '?url', import: 'default' }
);

type PartnerItem = { name: string; logo?: string; url?: string };

const items: Array<{ name: string; src?: string; url?: string }> =
  (partnersData.items as PartnerItem[])
    .sort((a, b) => a.name.localeCompare(b.name))
    .map(p => {
      const src = p.logo ? (logoUrls[`../../assets/logos/${p.logo}`] ?? '') : '';
      return { name: p.name, src: src || undefined, url: p.url };
    });

const duration = Math.round(items.length * 2.5);
---

<section class="marquee" id="partners">
  <p class="label">Powered by leading research institutions and organizations across Europe</p>
  <div class="track-wrap">
    <div class="track" style={`animation-duration: ${duration}s`}>
      {[...items, ...items].map((item, i) => (
        item.src ? (
          <a
            href={item.url || undefined}
            target={item.url ? '_blank' : undefined}
            rel={item.url ? 'noopener noreferrer' : undefined}
            class="logo-link"
            aria-label={item.name}
            aria-hidden={i >= items.length ? 'true' : undefined}
            tabindex={i >= items.length ? -1 : undefined}
          >
            <img src={item.src} alt={item.name} class="logo-img" loading="lazy" />
          </a>
        ) : (
          <span
            class="name-pill"
            aria-hidden={i >= items.length ? 'true' : undefined}
          >
            {item.name}
          </span>
        )
      ))}
    </div>
  </div>
</section>

<style>
  .marquee {
    width: min(1320px, 100% - 40px);
    margin: 0 auto;
    height: var(--marquee-height);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 18px 0 25px 0;
    overflow: hidden;
  }

  .label {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 14px;
    color: var(--color-neutral-400);
    text-align: center;
    margin: 0 0 30px;
    flex-shrink: 0;
  }

  .track-wrap {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .track {
    display: flex;
    align-items: center;
    gap: 60px;
    width: max-content;
    padding: 0 28px;
    animation: marquee-scroll linear infinite;
  }

  .logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    height: 50px;
    text-decoration: none;
  }

  .logo-img {
    display: block;
    height: 45px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.9) contrast(0.4);
    opacity: 0.75;
    transition: filter 0.5s ease, opacity 0.5s ease;
  }

  .logo-link:hover .logo-img {
    filter: none;
    opacity: 1;
  }

  .name-pill {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-neutral-400);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.75;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .label {
      font-size: 11px;
      margin-bottom: 14px;
      letter-spacing: 0.08em;
    }

    .logo-link {
      height: 40px;
    }

    .logo-img {
      height: 34px;
      max-width: 90px;
    }
  }

</style>
