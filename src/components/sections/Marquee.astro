---
import partners from '../../data/partners.yml';

const logoUrls = import.meta.glob<string>(
  '../../assets/logos/*',
  { eager: true, query: '?url', import: 'default' }
);

const items = partners.items.map(item => ({
  ...item,
  src: logoUrls[`../../assets/logos/${item.logo}`] ?? ''
}));
---

<section class="marquee">
  <p class="label">Trusted by leading research organizations across Europe</p>
  <div class="track-wrap">
    <div class="track">
      {[...items, ...items].map((item, i) => (
        <a
          href={item.url}
          target="_blank"
          rel="noopener noreferrer"
          class="logo-link"
          aria-label={item.name}
          aria-hidden={i >= items.length ? 'true' : undefined}
          tabindex={i >= items.length ? -1 : undefined}
        >
          <img src={item.src} alt={item.name} class="logo-img" loading="lazy" />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee {
    width: min(1320px, 100% - 40px);
    margin: 0 auto;
    height: var(--marquee-height);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 18px 0 25px 0;
    overflow: hidden;
  }

  .label {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 14px;
    color: var(--color-neutral-400);
    text-align: center;
    margin: 0 0 30px;
    flex-shrink: 0;
  }

  .track-wrap {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .track {
    display: flex;
    align-items: center;
    gap: 75px;
    width: max-content;
    padding: 0 28px;
    animation: marquee-scroll 36s linear infinite;
  }

  .logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    height: 50px;
    text-decoration: none;
  }

  .logo-img {
    display: block;
    height: 45px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.9) contrast(0.4);
    opacity: 0.75;
    transition: filter 0.5s ease, opacity 0.5s ease;
  }

  .logo-link:hover .logo-img {
    filter: none;
    opacity: 1;
  }
</style>
