---
import { getCollection } from 'astro:content';
import partnersData from '../../data/partners.yml';

const projectEntries = await getCollection('projects');

// partners.yml is a lookup: name → { logo, url }
const partnerMeta = new Map(
  (partnersData.items as Array<{ name: string; logo?: string; url?: string }>)
    .map(p => [p.name, p])
);

// Collect every unique partner name from all projects (lead + partners lists)
const allNames = new Set<string>();
for (const project of projectEntries) {
  if (project.data.lead) allNames.add(project.data.lead);
  for (const p of project.data.partners ?? []) allNames.add(p);
}

const logoUrls = import.meta.glob<string>(
  '../../assets/logos/*',
  { eager: true, query: '?url', import: 'default' }
);

// Resolve each name: check partners.yml for logo + url
const items: Array<{ name: string; src?: string; url?: string }> = Array.from(allNames)
  .sort((a, b) => a.localeCompare(b))
  .map(name => {
    const meta = partnerMeta.get(name);
    const src = meta?.logo ? (logoUrls[`../../assets/logos/${meta.logo}`] ?? '') : '';
    return { name, src: src || undefined, url: meta?.url };
  });
---

<section class="marquee" id="partners">
  <p class="label">Powered by leading research institutions and organizations across Europe</p>
  <div class="track-wrap">
    <div class="track">
      {[...items, ...items].map((item, i) => (
        item.src ? (
          <a
            href={item.url || undefined}
            target={item.url ? '_blank' : undefined}
            rel={item.url ? 'noopener noreferrer' : undefined}
            class="logo-link"
            aria-label={item.name}
            aria-hidden={i >= items.length ? 'true' : undefined}
            tabindex={i >= items.length ? -1 : undefined}
          >
            <img src={item.src} alt={item.name} class="logo-img" loading="lazy" />
          </a>
        ) : (
          <span
            class="name-pill"
            aria-hidden={i >= items.length ? 'true' : undefined}
          >
            {item.name}
          </span>
        )
      ))}
    </div>
  </div>
</section>

<style>
  .marquee {
    width: min(1320px, 100% - 40px);
    margin: 0 auto;
    height: var(--marquee-height);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 18px 0 25px 0;
    overflow: hidden;
  }

  .label {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 14px;
    color: var(--color-neutral-400);
    text-align: center;
    margin: 0 0 30px;
    flex-shrink: 0;
  }

  .track-wrap {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .track {
    display: flex;
    align-items: center;
    gap: 60px;
    width: max-content;
    padding: 0 28px;
    animation: marquee-scroll 90s linear infinite;
  }

  .logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    height: 50px;
    text-decoration: none;
  }

  .logo-img {
    display: block;
    height: 45px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.9) contrast(0.4);
    opacity: 0.75;
    transition: filter 0.5s ease, opacity 0.5s ease;
  }

  .logo-link:hover .logo-img {
    filter: none;
    opacity: 1;
  }

  .name-pill {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-neutral-400);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.75;
    text-transform: uppercase;
  }

</style>
