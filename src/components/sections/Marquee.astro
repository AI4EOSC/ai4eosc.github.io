---
import partners from '../../data/partners.yml';
---

<section class="marquee">
  <div class="container">
    <p class="label">{partners.label}</p>
    <div class="track">
      {partners.items.map((item) => (
        <span class="logo" key={item.name}>{item.name}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee {
    padding: 26px 0 12px;
  }

  .label {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 12px;
    color: var(--color-neutral-400);
    text-align: center;
    margin: 0 0 16px;
  }

  .track {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  @media (min-width: 900px) {
    .track {
      gap: 14px;
    }
  }

  .logo {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-neutral-400);
    padding: 7px 16px;
    border-radius: 10px;
    background: #ffffff;
    border: 0.5px solid var(--card-border);
  }
</style>
