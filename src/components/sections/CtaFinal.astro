---
import data from '../../data/cta.yml';
---

<section class="cta-wrap">
  <div class="container">
    <div class="cta">
      <div class="deco one"></div>
      <div class="deco two"></div>
      <h2>{data.title}</h2>
      <p>{data.description}</p>
      <a class="button-pill primary" href={data.button.href}>{data.button.label}</a>
    </div>
  </div>
</section>

<style>
  .cta-wrap {
    padding: 20px 0 0;
  }

  .cta {
    background:
      radial-gradient(500px 280px at 12% 20%, rgba(255, 255, 255, 0.14), transparent 70%),
      linear-gradient(140deg, var(--color-primary-700), var(--color-primary-500));
    border-radius: 24px 24px 0 0;
    padding: 56px;
    position: relative;
    overflow: hidden;
    color: #ffffff;
  }

  h2 {
    margin: 0 0 12px;
    font-family: var(--font-headings);
    font-size: 40px;
    font-weight: 500;
  }

  p {
    margin: 0 0 28px;
    color: rgba(255, 255, 255, 0.7);
    max-width: 500px;
    line-height: 1.65;
  }

  .deco {
    position: absolute;
    border-radius: 50%;
    border: 1px dashed rgba(255, 255, 255, 0.12);
  }

  .deco.one {
    width: 260px;
    height: 260px;
    right: -20px;
    top: -20px;
  }

  .deco.two {
    width: 180px;
    height: 180px;
    right: 80px;
    bottom: -60px;
  }

  @media (max-width: 720px) {
    .cta {
      padding: 36px 26px;
    }

    h2 {
      font-size: 28px;
    }
  }
</style>
