---
import data from '../../data/cta.yml';
---

<section class="cta-wrap">
  <div class="container">
    <div class="cta">
      <div class="cta-content">
        <h2>{data.title}</h2>
        <p>{data.description}</p>
        <a class="button-pill primary" href={data.button.href}>{data.button.label}</a>
      </div>
      <div class="cta-circles" aria-hidden="true">
        <span class="circle circle--lg"></span>
        <span class="circle circle--md"></span>
        <span class="circle circle--sm"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-wrap {
    padding: 20px 0 0;
  }

  .cta {
    background:
      radial-gradient(500px 280px at 12% 20%, rgba(255, 255, 255, 0.14), transparent 70%),
      linear-gradient(140deg, var(--color-primary-700), var(--color-primary-500));
    border-radius: 24px 24px 0 0;
    padding: 56px;
    position: relative;
    overflow: hidden;
    color: #ffffff;
  }

  h2 {
    margin: 0 0 12px;
    font-family: var(--font-headings);
    font-size: 46px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  p {
    margin: 0 0 28px;
    font-size: 17px;
    color: rgba(255, 255, 255, 0.7);
    max-width: 500px;
    line-height: 1.65;
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  @keyframes pulsing {
    0%, 100% { scale: 1; }
    50%       { scale: 1.05; }
  }

  .cta-circles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px dashed rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.04);
    animation: pulsing 5s ease-in-out infinite;
    transition: scale 2s ease;
  }

  .circle--lg { width: 80%; animation-delay: 2s; }
  .circle--md { width: 56%; animation-delay: 1s; }
  .circle--sm { width: 34%; animation-delay: 0s; }

  .cta:hover .circle {
    scale: 1.10;
  }

  @media (max-width: 720px) {
    .cta {
      padding: 36px 26px;
    }

    h2 {
      font-size: 28px;
    }
  }
</style>
