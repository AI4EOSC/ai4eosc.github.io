---
import hero from '../../data/hero.yml';
---

<section class="hero">
  <div class="hero-container">
    <div class="hero-badge">
      {hero.badge.dotLabel && <span class="dot" aria-hidden="true"></span>}
      {hero.badge.text}
    </div>
    <h1>{hero.title}</h1>
    <p>{hero.description}</p>
    <div class="hero-actions">
      <a class="button-pill primary" href={hero.cta.primary.href}>{hero.cta.primary.label}</a>
      <a class="button-pill ghost" href={hero.cta.secondary.href}>{hero.cta.secondary.label}</a>
    </div>
  </div>
  <div class="hero-circles" aria-hidden="true">
    <span class="circle circle--lg"></span>
    <span class="circle circle--md"></span>
    <span class="circle circle--sm"></span>
  </div>
</section>

<style>
  .hero {
    width: min(1320px, 100% - 20px);
    margin: 0 auto;
    height: calc(100vh - var(--marquee-height));
    height: calc(100svh - var(--marquee-height));
    min-height: 520px;
    border-radius: 0 0 28px 28px;
    background:
      radial-gradient(500px 280px at 10% 10%, rgba(255, 255, 255, 0.14), transparent 70%),
      linear-gradient(140deg, var(--color-primary-700), var(--color-primary-500));
    padding: calc(var(--nav-offset) + 30px) 72px 70px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    color: #ffffff;
  }

  .hero-container {
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.85);
    padding: 6px 16px;
    border-radius: 999px;
    border: 0.5px solid rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.18);
    margin-bottom: 50px;
  }

  .hero-badge .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #7fe8c4;
  }

  h1 {
    font-family: var(--font-headings);
    font-size: 56px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.03em;
    margin: 0 0 16px;
    max-width: 520px;
  }

  p {
    font-size: 18px;
    line-height: 1.25;
    max-width: 430px;
    margin: 0 0 50px;
    color: rgba(255, 255, 255, 0.75);
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  @keyframes pulsing {
    0%, 100% { scale: 1; }
    50%       { scale: 1.05; }
  }

  .hero-circles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px dashed rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.04);
    animation: pulsing 5s ease-in-out infinite;
    transition: scale 2s ease;
  }

  .circle--lg { width: 82%; animation-delay: 2s; }
  .circle--md { width: 58%; animation-delay: 1s; }
  .circle--sm { width: 36%; animation-delay: 0s; }

  .hero:hover .circle {
    scale: 1.10;
  }

  @media (max-width: 900px) {
    .hero {
      padding: calc(var(--nav-offset) + 20px) 42px 56px;
    }

    h1 {
      font-size: 38px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: calc(var(--nav-offset) + 16px) 26px 48px;
    }

    h1 {
      font-size: 34px;
    }
  }
</style>
