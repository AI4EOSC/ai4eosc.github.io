---
import data from '../../data/products.yml';
import SectionHeader from '../SectionHeader.astro';

const icons: Record<string, string> = {
  platform: `<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>`,
  llm: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  agents: `<circle cx="12" cy="7" r="4"/><path d="M5 21a7 7 0 0 1 14 0"/>`,
};
---

<section>
  <div class="section-label">
    <div class="container">{data.label}</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title={data.title}
        subtitle={data.description}
        actionLabel={data.action.label}
        actionHref={data.action.href}
      />
      <div class="grid">
        {data.items.map((item) => (
          <article class="card glass" key={item.title}>
            <div class={`screen ${item.theme}`}>
              <span class="circle circle--lg" aria-hidden="true"></span>
              <span class="circle circle--md" aria-hidden="true"></span>
              <span class="circle circle--sm" aria-hidden="true"></span>
              <div class="screen-label">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="white"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={icons[item.iconId]}
                />
                <span class="screen-name">{item.title}</span>
              </div>
            </div>
            <div class="body">
              <span class="badge">{item.category}</span>
              <p>{item.description}</p>
              <a class="link" href={item.linkHref}>{item.linkLabel}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .card {
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .screen {
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 0 0 0 22px;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse 55% 80% at 5% 50%, rgba(0, 135, 146, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 40% 70% at 92% 50%, rgba(236, 93, 128, 0.10) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(255, 255, 255, 0.04) 0%, transparent 50%),
      linear-gradient(140deg, #111418 0%, #1a1f24 50%, #1e2228 100%);
  }

  .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    animation: pulsing 5s ease-in-out infinite;
    z-index: 0;
  }

  .circle--lg { width: 90%; animation-delay: 2s; }
  .circle--md { width: 62%; animation-delay: 1s; }
  .circle--sm { width: 38%; animation-delay: 0s; }

  .screen.eu-blue .circle {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.18),
      0 0 30px rgba(46, 104, 212, 0.22),
      0 0 60px rgba(46, 104, 212, 0.10),
      inset 0 0 12px rgba(255, 255, 255, 0.03);
  }

  .screen.secondary .circle {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.18),
      0 0 30px rgba(236, 93, 128, 0.22),
      0 0 60px rgba(236, 93, 128, 0.10),
      inset 0 0 12px rgba(255, 255, 255, 0.03);
  }

  .screen.primary .circle {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.18),
      0 0 30px rgba(0, 200, 215, 0.22),
      0 0 60px rgba(0, 200, 215, 0.10),
      inset 0 0 12px rgba(255, 255, 255, 0.03);
  }

  .screen-label {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 18px;
    padding-left: 4px;
  }

  .screen-name {
    font-size: 20px;
    font-weight: 500;
    color: white;
    white-space: nowrap;
  }

  .body {
    padding: 16px 18px 20px;
  }

  .badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary-700);
    background: var(--color-primary-100);
    border-radius: 999px;
    padding: 3px 10px;
    margin-bottom: 8px;
  }

  p {
    margin: 0 0 10px;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-neutral-500);
  }

  .link {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-primary-700);
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
