---
import data from '../../data/products.yml';
import SectionHeader from '../SectionHeader.astro';

const MAX_ITEMS = 2;
---

<section>
  <div class="section-label">
    <div class="container">{data.label}</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title={data.title}
        subtitle={data.description}
        actionLabel={data.action.label}
        actionHref={data.action.href}
      />
      <div class="grid">
        {data.items.slice(0, MAX_ITEMS).map((item) => (
          <article class="card glass" key={item.title}>
            <div class={`screen ${item.theme}`}>
              <span class="circle circle--lg" aria-hidden="true"></span>
              <span class="circle circle--md" aria-hidden="true"></span>
              <span class="circle circle--sm" aria-hidden="true"></span>
              <span class="icon">{item.icon}</span>
            </div>
            <div class="body">
              <span class="badge">{item.category}</span>
              <h4>{item.title}</h4>
              <p>{item.description}</p>
              <a class="link" href={item.linkHref}>{item.linkLabel}</a>
            </div>
          </article>
        ))}
        <a class="card more" href={data.more.href}>{data.more.label}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .card {
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .screen {
    height: 78px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    position: relative;
    overflow: hidden;
  }

  .screen.primary {
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(255, 255, 255, 0.18) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 10% 10%, rgba(0, 200, 215, 0.20) 0%, transparent 55%),
      linear-gradient(135deg, var(--color-primary-700) 0%, var(--color-primary-500) 60%, var(--color-primary-400) 100%);
  }

  .screen.dark {
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(255, 255, 255, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 10% 10%, rgba(0, 135, 146, 0.15) 0%, transparent 55%),
      radial-gradient(ellipse 35% 35% at 85% 85%, rgba(236, 93, 128, 0.10) 0%, transparent 55%),
      linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #2a2040 100%);
  }

  .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.26),
      0 0 30px rgba(255, 255, 255, 0.14),
      0 0 60px rgba(255, 255, 255, 0.06),
      inset 0 0 12px rgba(255, 255, 255, 0.05);
    animation: pulsing 5s ease-in-out infinite;
    z-index: 0;
  }

  .circle--lg { width: 90%; animation-delay: 2s; }
  .circle--md { width: 62%; animation-delay: 1s; }
  .circle--sm { width: 38%; animation-delay: 0s; }

  .icon {
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.40));
  }

  .body {
    padding: 16px 18px 20px;
  }

  .badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-primary-700);
    background: var(--color-primary-100);
    border-radius: 999px;
    padding: 3px 10px;
    margin-bottom: 8px;
  }

  h4 {
    margin: 0 0 6px;
    font-size: 14px;
    font-weight: 600;
  }

  p {
    margin: 0 0 10px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-neutral-500);
  }

  .link {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary-700);
    text-decoration: none;
  }

  .more {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0.5px dashed var(--color-neutral-300);
    color: var(--color-neutral-400);
    text-decoration: none;
    min-height: 60px;
    font-size: 13px;
    grid-column: 1 / -1;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .more {
      grid-column: auto;
    }
  }
</style>
