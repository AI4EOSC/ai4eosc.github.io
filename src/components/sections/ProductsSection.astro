---
import SectionHeader from '../ui/SectionHeader.astro';
---

<section>
  <div class="section-label">
    <div class="container">Products</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title="Our software"
        subtitle="Open-source tools built to make research-grade AI accessible across the European Open Science Cloud."
        actionLabel="View all products"
        actionHref="/products"
      />
      <div class="grid">

        <!-- Platform -->
        <a class="cell reveal" href="/products#platform" style="transition-delay:0ms">
          <div class="product-render">
            <div class="chrome">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
              <span class="url">dashboard.cloud.ai4eosc.eu</span>
            </div>
            <div class="render-body">
              <div class="stat-row">
                <div class="stat"><span class="stat-n">247</span><span class="stat-l">Models</span></div>
                <div class="stat"><span class="stat-n">1.2k</span><span class="stat-l">Users</span></div>
                <div class="stat"><span class="stat-n">12</span><span class="stat-l">Gateways</span></div>
              </div>
              <div class="divider"></div>
              <div class="job">
                <div class="job-row"><span class="job-name">Training #142</span><span class="job-pct">68%</span></div>
                <div class="track"><div class="fill" style="width:68%"></div></div>
              </div>
              <div class="job">
                <div class="job-row"><span class="job-name">Serving #89</span><span class="job-pct active">Active</span></div>
                <div class="track"><div class="fill" style="width:100%;opacity:0.45"></div></div>
              </div>
              <div class="divider"></div>
              <div class="model-list">
                <div class="model-row">
                  <span class="model-led led-on"></span>
                  <span class="model-name">ResNet-50-marine</span>
                  <span class="model-badge">Serving</span>
                </div>
                <div class="model-row">
                  <span class="model-led led-train"></span>
                  <span class="model-name">BERT-multilingual</span>
                  <span class="model-badge badge-train">Training</span>
                </div>
                <div class="model-row">
                  <span class="model-led led-off"></span>
                  <span class="model-name">YOLOv8-climate</span>
                  <span class="model-badge badge-off">Queued</span>
                </div>
              </div>
            </div>
          </div>
          <div class="cell-body">
            <div class="cell-top">
              <span class="category">Core platform</span>
              <span class="status available">Available</span>
            </div>
            <h3>AI4EOSC Platform</h3>
            <p>The base infrastructure for deploying and managing AI models in EOSC.</p>
            <span class="link">Explore platform</span>
          </div>
        </a>

        <!-- LLM -->
        <a class="cell reveal" href="/products#llm" style="transition-delay:60ms">
          <div class="product-render">
            <div class="chrome">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
              <span class="url">chat.cloud.ai4eosc.eu</span>
            </div>
            <div class="render-body" style="justify-content:center">
              <div class="llm-badges">
                <span class="badge-pill">Mixtral-8x7B</span>
                <span class="badge-pill muted">EU-hosted</span>
              </div>
              <div class="chat-gap"></div>
              <div class="chat-row chat-row--end">
                <div class="bubble bubble-u">Summarise this research paper…</div>
                <div class="av av-u">U</div>
              </div>
              <div class="chat-row">
                <div class="av av-ai">AI</div>
                <div class="bubble bubble-ai">The paper presents a novel approach to federated learning with privacy guarantees…</div>
              </div>
              <div class="chat-row chat-row--end">
                <div class="bubble bubble-u">What are the key limitations?</div>
                <div class="av av-u">U</div>
              </div>
              <div class="chat-row">
                <div class="av av-ai">AI</div>
                <div class="bubble bubble-typing">
                  <span class="tydot"></span><span class="tydot"></span><span class="tydot"></span>
                </div>
              </div>
            </div>
          </div>
          <div class="cell-body">
            <div class="cell-top">
              <span class="category">Language models</span>
              <span class="status preview">Preview</span>
            </div>
            <h3>AI4EOSC LLM</h3>
            <p>Large language model services tailored for research use cases on EOSC infrastructure.</p>
            <span class="link">Explore LLM</span>
          </div>
        </a>

        <!-- Agents -->
        <a class="cell reveal" href="/products#agents" style="transition-delay:120ms">
          <div class="product-render">
            <div class="chrome">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
              <span class="url">agents.cloud.ai4eosc.eu</span>
            </div>
            <div class="render-body" style="justify-content:center">
              <div class="pipeline">
                <div class="pipe-step">
                  <div class="node node--done">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span class="pipe-lbl">Retrieve</span>
                </div>
                <div class="pipe-line pipe-line--done"></div>
                <div class="pipe-step">
                  <div class="node node--active">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3"/></svg>
                  </div>
                  <span class="pipe-lbl">Process</span>
                </div>
                <div class="pipe-line"></div>
                <div class="pipe-step">
                  <div class="node node--pending">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  </div>
                  <span class="pipe-lbl">Deliver</span>
                </div>
              </div>
              <div class="divider"></div>
              <div class="conn-title">Connected services</div>
              <div class="conn-grid">
                <div class="conn-chip chip-on">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                  EOSC Search
                </div>
                <div class="conn-chip chip-active">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3"/></svg>
                  LLM API
                </div>
                <div class="conn-chip chip-on">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                  Nextcloud storage
                </div>
                <div class="conn-chip chip-on">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                  OSCAR
                </div>
              </div>
              <div class="ag-status">
                <span class="ag-dot"></span>
                Running step 2 of 3
                <span class="step-dots">
                  <span class="sdot sdot-done"></span>
                  <span class="sdot sdot-active"></span>
                  <span class="sdot sdot-pending"></span>
                </span>
              </div>
            </div>
          </div>
          <div class="cell-body">
            <div class="cell-top">
              <span class="category">AI agents</span>
              <span class="status coming-soon">Coming soon</span>
            </div>
            <h3>AI4EOSC Agents</h3>
            <p>Autonomous AI agents for research automation, built on top of the EOSC infrastructure.</p>
            <span class="link">Learn more</span>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--card-border);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xs);
    overflow: hidden;
    margin-top: 24px;
  }

  .cell {
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    position: relative;
    transition:
      background var(--transition-fast),
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }

  .cell:hover {
    background: var(--color-neutral-50);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.09), 0 2px 8px rgba(0,0,0,0.04);
    z-index: 1;
  }

  /* ── Preview illustration ── */
  .product-render {
    background: white;
    border-bottom: 1px solid var(--card-border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    flex: 0 0 245px;
    max-height: 245px;
    position: relative;
  }

  .product-render::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.22) 50%,
      transparent 70%
    );
    transform: translateX(-120%) skewX(-12deg);
    transition: transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 10;
  }

  .cell:hover .product-render::after {
    transform: translateX(220%) skewX(-12deg);
  }

  .chrome {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 7px 12px;
    background: var(--color-primary-50);
    border-bottom: 1px solid var(--color-primary-100);
    flex-shrink: 0;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary-200);
    flex-shrink: 0;
  }

  .url {
    font-size: 9px;
    font-weight: 500;
    color: var(--color-primary-500);
    margin-left: 6px;
    letter-spacing: 0.02em;
    font-family: monospace;
  }

  .render-body {
    padding: 14px 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  /* Platform stats */
  .stat-row {
    display: flex;
    gap: 6px;
  }

  .stat {
    flex: 1;
    background: white;
    border: 0.5px solid var(--color-primary-200);
    border-radius: 4px;
    padding: 6px 8px;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .stat-n {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-primary-700);
    line-height: 1;
  }

  .stat-l {
    font-size: 8px;
    color: var(--color-primary-400);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .divider {
    height: 1px;
    background: var(--color-primary-100);
  }

  .job { display: flex; flex-direction: column; gap: 4px; }

  .job-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .job-name {
    font-size: 9px;
    color: var(--color-primary-600);
    font-weight: 500;
  }

  .job-pct {
    font-size: 9px;
    font-weight: 600;
    color: var(--color-primary-700);
  }

  .job-pct.active { color: var(--color-primary-500); }

  .track {
    height: 3px;
    background: var(--color-primary-100);
    border-radius: 99px;
    overflow: hidden;
  }

  .fill {
    height: 100%;
    background: var(--color-primary-500);
    border-radius: 99px;
  }

  /* LLM chat */
  .llm-badges { display: flex; gap: 5px; flex-wrap: wrap; }

  .badge-pill {
    font-size: 9px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 99px;
    border: 0.5px solid var(--color-primary-300);
    color: var(--color-primary-700);
    background: white;
  }

  .badge-pill.muted {
    border-color: var(--color-primary-200);
    color: var(--color-primary-500);
    background: transparent;
  }

  .chat-row { display: flex; align-items: flex-end; gap: 6px; }
  .chat-row--end { justify-content: flex-end; }

  .av {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .av-u { background: var(--color-primary-100); color: var(--color-primary-600); }
  .av-ai { background: var(--color-primary-600); color: white; }

  .bubble {
    font-size: 9px;
    line-height: 1.4;
    padding: 5px 8px;
    border-radius: 6px;
    max-width: 80%;
  }

  .bubble-u {
    background: white;
    color: var(--color-neutral-600);
    border: 0.5px solid var(--color-primary-200);
    border-radius: 6px 6px 0 6px;
  }

  .bubble-ai {
    background: var(--color-primary-100);
    color: var(--color-primary-800);
    border: 0.5px solid var(--color-primary-200);
    border-radius: 6px 0 6px 6px;
  }

  /* Agents pipeline */
  .pipeline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 4px 0;
  }

  .node {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1.5px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
  }

  .node--done {
    background: var(--color-primary-100);
    border-color: var(--color-primary-400);
    color: var(--color-primary-600);
  }

  .node--active {
    background: var(--color-primary-600);
    border-color: var(--color-primary-500);
    color: white;
    box-shadow: 0 0 10px var(--color-primary-200);
  }

  .node--pending {
    background: white;
    border-color: var(--color-primary-200);
    color: var(--color-primary-300);
  }

  .pipe-line {
    flex: 1;
    height: 1.5px;
    background: var(--color-primary-200);
  }

  .pipe-line--done { background: var(--color-primary-400); }

  .ag-status {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 9px;
    color: var(--color-primary-600);
    font-weight: 500;
    margin-top: 4px;
  }

  .ag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-primary-500);
    animation: pulsing 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .ag-note {
    font-size: 8px;
    color: var(--color-primary-400);
  }

  /* ── Cell body (text area below preview) ── */
  .cell-body {
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .cell-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .category {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-neutral-400);
    flex: 1;
    white-space: nowrap;
  }

  .status {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 999px;
    border: 1px solid;
    white-space: nowrap;
  }

  .status.available   { color: #059669; border-color: #a7f3d0; background: #f0fdf4; }
  .status.preview     { color: #b45309; border-color: #fde68a; background: #fffbeb; }
  .status.coming-soon { color: var(--color-neutral-400); border-color: var(--card-border); background: transparent; }

  h3 {
    margin: 0 0 8px;
    font-family: var(--font-headings);
    font-size: 19px;
    font-weight: 650;
    letter-spacing: -0.01em;
    color: var(--color-neutral-900);
  }

  p {
    margin: 0 0 18px;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-neutral-500);
    flex: 1;
  }

  .link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary-700);
    text-decoration: none;
    margin-top: auto;
    transition: color var(--transition-fast);
  }

  .cell:hover .link { color: var(--color-primary-600); }

  /* ── Platform model list ── */
  .model-list { display: flex; flex-direction: column; gap: 4px; }

  .model-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .model-led {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .led-on    { background: #22c55e; }
  .led-train { background: var(--color-primary-400); animation: pulsing 2s ease-in-out infinite; }
  .led-off   { background: var(--color-neutral-300); }

  .model-name {
    font-size: 9px;
    color: var(--color-primary-600);
    font-weight: 500;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .model-badge {
    font-size: 8px;
    font-weight: 600;
    padding: 1px 5px;
    border-radius: 3px;
    background: #dcfce7;
    color: #166534;
    flex-shrink: 0;
  }

  .model-badge.badge-train { background: var(--color-primary-50); color: var(--color-primary-700); }
  .model-badge.badge-off   { background: var(--color-neutral-100); color: var(--color-neutral-500); }

  /* LLM badge → chat gap */
  .chat-gap { height: 6px; flex-shrink: 0; }

  /* ── LLM typing indicator ── */
  .bubble-typing {
    display: flex;
    align-items: center;
    gap: 3px;
    padding: 7px 10px;
    background: var(--color-primary-50);
    border: 0.5px solid var(--color-primary-100);
    border-radius: 6px 0 6px 6px;
  }

  .tydot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary-400);
    animation: pulsing 1.4s ease-in-out infinite;
  }

  .tydot:nth-child(2) { animation-delay: 0.2s; }
  .tydot:nth-child(3) { animation-delay: 0.4s; }

  /* Agents pipeline: node + label stacked, aligned */
  .pipe-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
  }

  .pipe-lbl {
    font-size: 8px;
    color: var(--color-primary-500);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* Agents step pills inline */
  .step-dots {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-left: auto;
  }

  .sdot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .sdot-done    { background: var(--color-primary-300); }
  .sdot-active  { background: var(--color-primary-600); }
  .sdot-pending { background: var(--color-primary-100); border: 1px solid var(--color-primary-200); }

  /* ── Agents connected services ── */
  .conn-title {
    font-size: 8px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-400);
  }

  .conn-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .conn-chip {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 8.5px;
    font-weight: 600;
    padding: 4px 7px;
    border-radius: 4px;
    border: 0.5px solid;
  }

  .chip-on {
    background: var(--color-primary-50);
    border-color: var(--color-primary-200);
    color: var(--color-primary-600);
  }

  .chip-active {
    background: var(--color-primary-600);
    border-color: var(--color-primary-500);
    color: white;
    box-shadow: 0 0 8px var(--color-primary-200);
  }

  @media (max-width: 860px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
