---
import { getCollection } from 'astro:content';
import SectionHeader from '../SectionHeader.astro';

const stories = await getCollection('stories');
const sortedStories = stories
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section>
  <div class="section-label">
    <div class="container">Latest stories</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title="From the initiative"
        subtitle="News, case studies and research highlights from across the AI4EOSC ecosystem."
        actionLabel="All stories →"
        actionHref="/stories"
      />
      <div class="grid">
        {sortedStories.map((story, i) => (
          <a
            href={story.data.externalUrl ?? `/stories/${story.id}`}
            class={`item reveal${story.data.image ? ' has-image' : ''}`}
            style={`transition-delay: ${i * 80}ms`}
            {...(story.data.externalUrl ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {story.data.image && (
              <div class="image">
                <img src={story.data.image} alt="" loading="lazy" />
              </div>
            )}
            <div class="body">
              <div class="meta">
                <span class="tag">{story.data.type}</span>
                <span class="dot" aria-hidden="true"></span>
                <span class="date">
                  {story.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
                </span>
              </div>
              <h4>{story.data.title}</h4>
              <p>{story.data.excerpt}</p>
              <span class="read-link">{story.data.externalUrl ? 'View on external site ↗' : 'Read story →'}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 24px;
    border-top: 1px solid var(--card-border);
  }

  .item {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
  }

  /* Image: full-width bleed, no radius, flush to top */
  .image {
    width: 100%;
    height: 150px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--card-border);
    background: linear-gradient(135deg, #001a1c 0%, var(--color-primary-800) 60%, var(--color-primary-700) 100%);
  }

  .image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: luminosity;
    opacity: 0.55;
  }

  /* Body carries the horizontal padding */
  .body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 24px 32px 28px 0;
  }

  .item + .item .body { padding-left: 31px; border-left: 1px solid var(--card-border); }
  .item:last-child .body { padding-right: 0; }

  /* No top padding on body when there's no image */
  .item:not(.has-image) .body { padding-top: 28px; }

  .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-600);
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-neutral-300);
    flex-shrink: 0;
  }

  .date {
    font-size: 13px;
    color: var(--color-neutral-400);
  }

  h4 {
    margin: 0 0 10px;
    font-family: var(--font-headings);
    font-size: 19px;
    font-weight: 650;
    color: var(--color-neutral-800);
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
  }

  .item:hover h4 { color: var(--color-primary-700); }

  p {
    margin: 0 0 20px;
    font-size: 16px;
    color: var(--color-neutral-500);
    line-height: 1.6;
    flex: 1;
  }

  .read-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary-700);
    margin-top: auto;
    transition: color var(--transition-fast);
  }

  .item:hover .read-link { color: var(--color-primary-600); }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      border-top: none;
    }

    .item {
      border-right: none;
      border-top: 1px solid var(--card-border);
    }

    .body { padding: 24px 0 24px 0 !important; }
  }
</style>
