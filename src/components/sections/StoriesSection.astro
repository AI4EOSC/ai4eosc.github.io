---
import { getCollection } from 'astro:content';
import SectionHeader from '../SectionHeader.astro';

const stories = await getCollection('stories');
const sortedStories = stories.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const posGradients = ['dark', 'secondary', 'primary'];
---

<section>
  <div class="section-label">
    <div class="container">Latest stories</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title="From the initiative"
        subtitle="News, case studies and research highlights from across the AI4EOSC ecosystem."
        actionLabel="All stories →"
        actionHref="/stories"
      />
      <div class="grid">
        {sortedStories.map((story, i) => (
          <article class="card glass" key={story.data.title}>
            <div class={`image ${posGradients[i % 3]}`}>
              {story.data.image && (
                <img src={story.data.image} alt="" class="cover" loading="lazy" />
              )}
            </div>
            <div class="body">
              <div class="meta">
                <span class="tag">{story.data.type}</span>
                <span class="date">
                  {story.data.date.toLocaleDateString('en-GB', {
                    month: 'short',
                    year: 'numeric'
                  })}
                </span>
              </div>
              <h4>{story.data.title}</h4>
              <p>{story.data.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .card {
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .image {
    height: 220px;
    position: relative;
    overflow: hidden;
  }

  /* Imagen encima de los círculos, semitransparente */
  .cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
    z-index: -1;
  }

  /* Círculos debajo de la imagen — su neon se filtra a través */
  .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    animation: pulsing 5s ease-in-out infinite;
    z-index: 1;
  }

  .circle--lg { width: 70%; animation-delay: 2s; }
  .circle--md { width: 50%; animation-delay: 1s; }
  .circle--sm { width: 30%; animation-delay: 0s; }

  /* Neon sobre fondo oscuro — ring blanco + glow coloreado */
  .image.dark .circle {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.22),
      0 0 30px rgba(46, 104, 212, 0.55),
      0 0 70px rgba(46, 104, 212, 0.28),
      inset 0 0 12px rgba(255, 255, 255, 0.04);
  }

  .image.secondary .circle {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.22),
      0 0 30px rgba(236, 93, 128, 0.55),
      0 0 70px rgba(236, 93, 128, 0.28),
      inset 0 0 12px rgba(255, 255, 255, 0.04);
  }

  .image.primary .circle {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.22),
      0 0 30px rgba(0, 200, 215, 0.55),
      0 0 70px rgba(0, 200, 215, 0.28),
      inset 0 0 12px rgba(255, 255, 255, 0.04);
  }

  .body {
    padding: 16px 18px 20px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .tag {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary-700);
    background: var(--color-primary-100);
    border-radius: 999px;
    padding: 2px 8px;
  }

  .date {
    font-size: 14px;
    color: var(--color-neutral-400);
  }

  h4 {
    margin: 0 0 6px;
    font-size: 18px;
    font-weight: 600;
    color: var(--color-neutral-800);
    line-height: 1.35;
  }

  p {
    margin: 0;
    font-size: 16px;
    color: var(--color-neutral-500);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
