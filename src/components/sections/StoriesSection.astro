---
import { getCollection } from 'astro:content';
import SectionHeader from '../SectionHeader.astro';

const stories = await getCollection('stories');
const sortedStories = stories.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const placeholderColors: Record<string, string> = {
  dark:      'var(--color-neutral-800)',
  secondary: 'var(--color-secondary-700)',
  primary:   'var(--color-primary-700)',
};

const posGradients = ['dark', 'secondary', 'primary'];
---

<section>
  <div class="section-label">
    <div class="container">Latest stories</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title="From the initiative"
        subtitle="News, case studies and research highlights from across the AI4EOSC ecosystem."
        actionLabel="All stories →"
        actionHref="/stories"
      />
      <div class="grid">
        {sortedStories.map((story, i) => {
          const gradient = story.data.gradient ?? posGradients[i % 3];
          const bgColor = placeholderColors[gradient];
          return (
            <a href={`/stories/${story.id}`} class="card reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="image" style={`background-color: ${bgColor}`}>
                {story.data.image && (
                  <img src={story.data.image} alt="" class="cover" loading="lazy" />
                )}
              </div>
              <div class="body">
                <div class="meta">
                  <span class="tag">{story.data.type}</span>
                  <span class="date">
                    {story.data.date.toLocaleDateString('en-GB', {
                      month: 'short',
                      year: 'numeric'
                    })}
                  </span>
                </div>
                <h4>{story.data.title}</h4>
                <p>{story.data.excerpt}</p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    display: block;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-2);
  }

  .image {
    height: 160px;
    position: relative;
    overflow: hidden;
  }

  .cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .body {
    padding: 18px 20px 20px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-600);
  }

  .date {
    font-size: 13px;
    color: var(--color-neutral-400);
  }

  h4 {
    margin: 0 0 6px;
    font-family: var(--font-headings);
    font-size: 17px;
    font-weight: 650;
    color: var(--color-neutral-800);
    line-height: 1.35;
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
  }

  .card:hover h4 { color: var(--color-primary-700); }

  p {
    margin: 0;
    font-size: 14px;
    color: var(--color-neutral-500);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
