---
import { getCollection } from 'astro:content';
import SectionHeader from '../SectionHeader.astro';

const stories = await getCollection('stories');
const sortedStories = stories.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<section>
  <div class="section-label">
    <div class="container">Latest stories</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title="From the initiative"
        subtitle="News, case studies and research highlights from across the AI4EOSC ecosystem."
        actionLabel="All stories →"
        actionHref="/stories"
      />
      <div class="grid">
        {sortedStories.map((story) => (
          <article class="card" key={story.data.title}>
            <div class={`image ${story.data.gradient ?? 'primary'}`}>
              {story.data.icon}
            </div>
            <div class="body">
              <div class="meta">
                <span class="tag">{story.data.type}</span>
                <span class="date">
                  {story.data.date.toLocaleDateString('en-GB', {
                    month: 'short',
                    year: 'numeric'
                  })}
                </span>
              </div>
              <h4>{story.data.title}</h4>
              <p>{story.data.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .card {
    background: var(--color-neutral-50);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 12px 26px rgba(0, 0, 0, 0.05);
  }

  .image {
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
  }

  .image.primary {
    background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-400));
  }

  .image.secondary {
    background: linear-gradient(135deg, var(--color-secondary-600), var(--color-secondary-400));
  }

  .image.dark {
    background: linear-gradient(135deg, #2d4a8a, #5b7fd4);
  }

  .body {
    padding: 14px 16px 18px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-primary-700);
    background: var(--color-primary-100);
    border-radius: 999px;
    padding: 2px 8px;
  }

  .date {
    font-size: 11px;
    color: var(--color-neutral-300);
  }

  h4 {
    margin: 0 0 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-neutral-900);
    line-height: 1.45;
  }

  p {
    margin: 0;
    font-size: 12px;
    color: var(--color-neutral-400);
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
