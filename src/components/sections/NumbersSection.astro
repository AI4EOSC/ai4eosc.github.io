---
import numbersData from '../../data/numbers.yml';
import projectsData from '../../data/projects.yml';
import communitiesData from '../../data/communities.yml';
import gatewaysData from '../../data/gateways.yml';
import SectionHeader from '../ui/SectionHeader.astro';

type Tone = 'eu-blue' | 'secondary' | 'primary' | 'neutral';

const toneConfig: Record<Tone, { bg: string; color: string }> = {
  'eu-blue':   { bg: '#dbeafe', color: '#2563eb' },
  'secondary': { bg: 'var(--color-secondary-50)', color: 'var(--color-secondary-600)' },
  'primary':   { bg: 'var(--color-primary-50)',   color: 'var(--color-primary-600)'   },
  'neutral':   { bg: 'var(--color-neutral-100)',  color: 'var(--color-neutral-500)'   },
};

const iconSvg: Record<string, string> = {
  star:   `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
  users:  `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  server: `<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
  box:    `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>`,
};

const projectCount = projectsData.items.length;
const userCount = (communitiesData.items as Array<{ users?: number }>)
  .reduce((sum, c) => sum + (c.users ?? 0), 0);
const gatewayCount = gatewaysData.items.length;

function formatCount(n: number): { value: string; suffix: string } {
  if (n >= 1_000_000) {
    const v = n / 1_000_000;
    return { value: v % 1 === 0 ? String(v) : v.toFixed(1), suffix: 'M+' };
  }
  if (n >= 1_000) {
    const v = n / 1_000;
    return { value: v % 1 === 0 ? String(v) : v.toFixed(1), suffix: 'K+' };
  }
  return { value: String(n), suffix: '+' };
}

const computedFormatted = [
  formatCount(projectCount),
  formatCount(userCount),
  formatCount(gatewayCount),
];

const items = (numbersData.items as Array<Record<string, string>>).map((item, i) => {
  if (i < computedFormatted.length) {
    const fmt = computedFormatted[i];
    return { ...item, value: fmt.value, suffix: fmt.suffix };
  }
  return item;
});
---

<section>
  <div class="section-label">
    <div class="container">The initiative in numbers</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader title="Impact at scale" subtitle="Powering open AI infrastructure across Europe — from model training to scientific communities." />
      <div class="grid">
        {items.map((item, i) => {
          const tone = toneConfig[item.tone as Tone] ?? toneConfig.neutral;
          const svg = iconSvg[item.icon] ?? iconSvg.box;
          return (
            <div class="stat reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="icon-wrap" style={`background: ${tone.bg}; color: ${tone.color};`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={svg} />
              </div>
              <div class="number">
                <span class="value">{item.value}</span><span class="suffix">{item.suffix}</span>
              </div>
              <p class="label">{item.label}</p>
              {item.detail && <p class="detail">{item.detail}</p>}
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      obs.unobserve(entry.target);

      const valueEl = entry.target.querySelector<HTMLElement>('.value');
      const suffixEl = entry.target.querySelector<HTMLElement>('.suffix');
      if (!valueEl) return;

      const raw = valueEl.textContent?.trim() ?? '0';
      const isDecimal = raw.includes('.');
      const target = parseFloat(raw);
      const isK = suffixEl?.textContent?.includes('K');
      const duration = isK ? 2200 : 1700;
      const start = performance.now();

      function tick(now: number) {
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 4);
        valueEl.textContent = isDecimal
          ? (target * eased).toFixed(1)
          : String(Math.round(target * eased));
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  }, { threshold: 0.6 });

  document.querySelectorAll('.stat').forEach(el => obs.observe(el));
</script>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 32px;
  }

  .stat {
    padding: 8px 36px;
    border-right: 1px solid var(--card-border);
  }

  .stat:first-child { padding-left: 0; }
  .stat:last-child { border-right: none; padding-right: 0; }

  .icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    flex-shrink: 0;
  }

  .number {
    display: flex;
    align-items: baseline;
    gap: 1px;
    margin-bottom: 10px;
    line-height: 1;
  }

  .value {
    font-family: var(--font-headings);
    font-size: 68px;
    font-weight: 650;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-neutral-900);
  }

  .suffix {
    font-family: var(--font-headings);
    font-size: 46px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-neutral-900);
  }

  .label {
    margin: 0 0 5px;
    font-size: 16px;
    font-weight: 500;
    color: var(--color-neutral-700);
    line-height: 1.4;
    max-width: 190px;
  }

  .detail {
    margin: 0;
    font-size: 16px;
    color: var(--color-neutral-400);
    line-height: 1.4;
    max-width: 190px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 36px 0;
    }

    .stat {
      padding: 0 24px;
      border-right: 1px solid var(--card-border);
    }

    .stat:nth-child(2n) {
      border-right: none;
      padding-right: 0;
    }

    .stat:nth-child(2n+1) {
      padding-left: 0;
    }
  }

  @media (max-width: 520px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .stat {
      padding: 0;
      border-right: none;
    }
  }
</style>
