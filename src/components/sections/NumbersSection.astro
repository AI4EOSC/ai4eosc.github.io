---
import data from '../../data/numbers.yml';
import SectionHeader from '../SectionHeader.astro';

const label = 'The initiative in numbers';
const title = 'Impact at scale';
const description = 'Powering open AI infrastructure across Europe — from model training to scientific communities.';
---

<section>
  <div class="section-label">
    <div class="container">{label}</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader title={title} subtitle={description} />
      <div class="grid">
        {data.items.map((item) => (
          <article class={`stat-card ${item.tone}`}>
            <div class="accent-bar"></div>
            <div class="body">
              <div class="value">
                {item.value}<span class="suffix">{item.suffix}</span>
              </div>
              <p class="label">{item.label}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  /* ── Stat card ── */
  .stat-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .stat-card.eu-blue {
    background: color-mix(in oklch, rgba(223, 233, 255, 0.6) 60%, white 40%);
    border: 1px solid rgba(46, 104, 212, 0.14);
  }

  .stat-card.secondary {
    background: color-mix(in oklch, var(--color-secondary-50) 60%, white 40%);
    border: 1px solid rgba(236, 93, 128, 0.14);
  }

  .stat-card.primary {
    background: color-mix(in oklch, var(--color-primary-50) 60%, white 40%);
    border: 1px solid rgba(0, 135, 146, 0.14);
  }

  .stat-card.neutral {
    background: color-mix(in oklch, var(--color-neutral-100) 50%, white 50%);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  /* ── Accent bar ── */
  .accent-bar {
    height: 3px;
    flex-shrink: 0;
  }

  .stat-card.eu-blue .accent-bar {
    background: linear-gradient(90deg, #2e68d4, transparent);
  }

  .stat-card.secondary .accent-bar {
    background: linear-gradient(90deg, var(--color-secondary-400), transparent);
  }

  .stat-card.primary .accent-bar {
    background: linear-gradient(90deg, var(--color-primary-400), transparent);
  }

  .stat-card.neutral .accent-bar {
    background: linear-gradient(90deg, var(--color-neutral-500), transparent);
  }

  /* ── Body ── */
  .body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* ── Value ── */
  .value {
    font-family: var(--font-headings);
    font-size: 60px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 10px;
  }

  .stat-card.eu-blue .value  { color: #2e68d4; }
  .stat-card.secondary .value { color: var(--color-secondary-500); }
  .stat-card.primary .value   { color: var(--color-primary-600); }
  .stat-card.neutral .value   { color: var(--color-neutral-700); }

  .suffix {
    font-size: 40px;
    opacity: 0.65;
  }

  /* ── Label ── */
  .label {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-neutral-500);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
