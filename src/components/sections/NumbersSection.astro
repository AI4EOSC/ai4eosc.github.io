---
import data from '../../data/numbers.yml';
import SectionHeader from '../SectionHeader.astro';
---

<section>
  <div class="section-label">
    <div class="container">The initiative in numbers</div>
  </div>
  <div class="container">
    <div class="section-card">
      <SectionHeader title="Impact at scale" subtitle="Powering open AI infrastructure across Europe — from model training to scientific communities." />
      <div class="grid">
        {data.items.map((item, i) => (
          <div class="stat reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="value">
              {item.value}<span class="suffix">{item.suffix}</span>
            </div>
            <p class="label">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 20px;
  }

  .stat {
    padding: 4px 32px;
    border-right: 1px solid var(--card-border);
  }

  .stat:first-child { padding-left: 0; }
  .stat:last-child { border-right: none; padding-right: 0; }

  .value {
    font-family: var(--font-headings);
    font-size: 64px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-neutral-900);
    margin-bottom: 10px;
  }

  .suffix {
    font-size: 42px;
    color: var(--color-primary-500);
  }

  .label {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-neutral-500);
    line-height: 1.4;
    max-width: 160px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 32px 0;
    }

    .stat {
      padding: 0 24px;
      border-right: 1px solid var(--card-border);
    }

    .stat:nth-child(2n) {
      border-right: none;
      padding-right: 0;
    }

    .stat:nth-child(2n+1) {
      padding-left: 0;
    }
  }

  @media (max-width: 520px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .stat {
      padding: 0;
      border-right: none;
    }
  }
</style>
