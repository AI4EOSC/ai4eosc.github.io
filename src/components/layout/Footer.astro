---
import footer from '../../data/footer.yml';

const currentYear = new Date().getFullYear();
---

<footer class="footer-wrap">
  <div class="footer">
    <div class="brand">
      <div class="brand-mark">
        <a class="brand" href="/">
            <img class="brand-logo" src="/logos/AI4-horizontal-light.svg" alt="AI4EOSC" />
        </a>
      </div>
      <p>{footer.brand.description}</p>
    </div>
    {footer.columns.map((column) => (
      <div class="column" key={column.title}>
        <h5>{column.title}</h5>
        {column.links.map((link) => (
          <a href={link.href} key={link.label}>{link.label}</a>
        ))}
      </div>
    ))}
    <div class="social">
      <a href="https://www.linkedin.com/company/ai4eosc" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://www.youtube.com/@ai4eosc" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      <a href="https://github.com/ai4eosc" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {currentYear} {footer.bottom.left}</p>
    <div class="policies">
      {footer.bottom.policies.map((policy: { label: string; href: string }, i: number) => (
        <>
          {i > 0 && <span class="sep">·</span>}
          <a href={policy.href}>{policy.label}</a>
        </>
      ))}
    </div>
    <p>{footer.bottom.right}</p>
  </div>
</footer>

<style>
  .footer-wrap {
    margin: 0 auto;
    width: min(1320px, 100% - 40px);
    background: #ffffff;
    border-top: 0.5px solid var(--card-border);
  }

  .footer {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr auto;
    gap: 26px;
    padding: 36px 40px 0;
  }

  .social {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 10px;
    padding-top: 5px;
  }

  .social a {
    color: var(--color-neutral-400);
    transition: color 0.15s ease;
    line-height: 0;
  }

  .social a:hover {
    color: var(--color-neutral-900);
  }

    /* ── Marca ─────────────────────────────────────────────────────── */

  .brand-logo {
    height: 90px;
    width: auto;
    margin-left: -35px;
    margin-top: -20px;
    margin-bottom: -2px;
  }

  .brand p {
    color: var(--color-neutral-500);
    line-height: 1.65;
    max-width: 375px;
  }

  .column h5 {
    margin: 0 0 12px;
    font-weight: 600;
    color: var(--color-neutral-900);
  }

  .column a {
    display: block;
    font-size: 16px;
    color: var(--color-neutral-500);
    margin-bottom: 7px;
    text-decoration: none;
  }

  .footer-bottom {
    border-top: 0.5px solid var(--card-border);
    margin-top: 28px;
    padding: 20px 40px 24px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font-size: 14px;
    color: var(--color-neutral-500);
  }

  .policies {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .policies .sep {
    color: var(--color-neutral-400);
  }

  .policies a {
    color: var(--color-neutral-500);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .policies a:hover {
    color: var(--color-neutral-900);
  }

  @media (max-width: 900px) {
    .footer {
      grid-template-columns: 1fr 1fr;
      padding: 32px 24px 0;
    }

    .social {
      flex-direction: row;
      justify-content: flex-start;
      grid-column: 1 / -1;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      padding: 18px 24px 22px;
    }
  }

  @media (max-width: 640px) {
    .footer {
      grid-template-columns: 1fr;
    }
  }
</style>
