---
import nav from '../../data/nav.yml';
import logoSrc from '../../assets/logos/AI4-horizontal-light.svg?url';
---

<header class="fixed top-5 left-1/2 -translate-x-1/2 w-[calc(100%-72px)] sm:w-[min(1200px,calc(100%-20px))] z-[200]">
  <div
    data-nav
    class="nav glass relative flex flex-col rounded-[40px] transition-shadow duration-300"
  >
    <!-- Row principal -->
    <div class="flex items-center justify-between gap-3.5 h-20 pr-5">

      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0 no-underline">
        <img src={logoSrc} alt="AI4EOSC" class="h-20 w-auto" />
      </a>

      <!-- Links centrales (desktop) -->
      <nav class="links flex gap-0.5 items-center mx-auto" aria-label="Primary">
        {nav.links.map((link) =>
          link.dropdown ? (
            <button
              class="nav-link"
              data-menu={link.label}
              type="button"
            >
              {link.label}
              <span class="chevron" aria-hidden="true">
                <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
          ) : (
            <a class="nav-link" data-no-menu href={link.href}>
              {link.label}
            </a>
          )
        )}
      </nav>

      <!-- CTA (desktop) + Hamburger (mobile) -->
      <div class="flex items-center gap-3 shrink-0">
        <a class="button-pill dark desktop-cta" href={nav.cta.href}>{nav.cta.label}</a>
        <button class="hamburger" data-hamburger aria-label="Toggle menu" aria-expanded="false" type="button">
          <span class="bar bar-1"></span>
          <span class="bar bar-2"></span>
          <span class="bar bar-3"></span>
        </button>
      </div>
    </div>

    <!-- Panel desplegable (desktop) -->
    <div data-nav-panel class="nav-panel">
      {nav.links
        .filter((link) => link.dropdown)
        .map((link) => (
          <div
            class="panel"
            data-panel={link.label}
            style={`grid-template-columns: repeat(${link.dropdown?.length ?? 1}, minmax(0, 1fr));`}
          >
            {link.dropdown?.map((item) => (
              <a
                class={`panel-item gradient-${item.hoverGradient ?? 'none'}`}
                href={item.href}
                {...(item.href?.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <span class="circle circle--lg" aria-hidden="true"></span>
                <span class="circle circle--md" aria-hidden="true"></span>
                <span class="circle circle--sm" aria-hidden="true"></span>
                <h4>{item.label}</h4>
                <p>{item.description}</p>
              </a>
            ))}
          </div>
        ))}
    </div>

    <!-- Mobile menu -->
    <div class="mobile-menu" data-mobile-menu aria-hidden="true">
      <div class="mob-inner">

        {nav.links.map((link) =>
          link.dropdown ? (
            <div class="mob-group" data-mob-group={link.label}>
              <button class="mob-trigger" data-mob-trigger={link.label} type="button">
                {link.label}
                <span class="mob-chevron" aria-hidden="true">
                  <svg width="12" height="7" viewBox="0 0 12 7" fill="none">
                    <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>
              <div class="mob-sub" data-mob-sub={link.label}>
                {link.dropdown?.map((item) => (
                  <a class="mob-sub-link" href={item.href} {...(item.href?.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                    <span class={`mob-sub-dot dot-${item.hoverGradient ?? 'none'}`} aria-hidden="true"></span>
                    <span class="mob-sub-text">
                      <span class="mob-sub-label">{item.label}</span>
                      <span class="mob-sub-desc">{item.description}</span>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a class="mob-link" href={link.href}>{link.label}</a>
          )
        )}

        <div class="mob-cta-wrap">
          <a class="button-pill dark mob-cta" href={nav.cta.href}>{nav.cta.label}</a>
        </div>

      </div>
    </div>

  </div>
</header>

<style>
  /* ── Desktop nav ────────────────────────────────────── */
  .nav.glass:hover {
    transform: none;
    box-shadow: var(--glass-shadow-neutral);
  }

  .nav.open {
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.12),
      inset 0 0 0 0.5px rgba(255, 255, 255, 0.5);
  }

  /* ── Links ──────────────────────────────────────────── */
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 7px 14px;
    border-radius: 999px;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-neutral-600);
    text-decoration: none;
    background: transparent;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    font-family: var(--font-body);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .nav-link:hover,
  .nav-link.active {
    background: rgba(0, 0, 0, 0.05);
    color: var(--color-neutral-900);
  }

  /* ── Chevron ────────────────────────────────────────── */
  .chevron {
    display: inline-flex;
    align-items: center;
    color: var(--color-neutral-400);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), color var(--transition-fast);
  }

  .nav-link.active .chevron {
    transform: rotate(180deg);
    color: var(--color-neutral-700);
  }

  /* ── Desktop dropdown panel ─────────────────────────── */
  .nav-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height var(--transition-slow), opacity 0.2s ease;
  }

  .nav.open .nav-panel {
    max-height: 300px;
    opacity: 1;
  }

  .nav.open .nav-panel::before {
    content: '';
    display: block;
    margin: 0 18px;
    height: 0.5px;
    background: rgba(0, 0, 0, 0.07);
  }

  .panel {
    display: none;
    gap: 10px;
    padding: 12px 16px 16px;
  }

  .nav[data-active="Ecosystem"] .panel[data-panel="Ecosystem"],
  .nav[data-active="Support"]   .panel[data-panel="Support"] {
    display: grid;
  }

  /* ── Panel items ────────────────────────────────────── */
  .panel-item {
    display: block;
    padding: 10px 10px 10px 20px;
    border-radius: 14px;
    text-decoration: none;
    background: rgba(0, 0, 0, 0.025);
    border: 0.5px solid transparent;
    position: relative;
    overflow: hidden;
    transition:
      background   var(--transition-base),
      border-color var(--transition-base),
      box-shadow   var(--transition-base),
      transform    var(--transition-fast);
  }

  .panel-item:first-child { border-bottom-left-radius:  24px; }
  .panel-item:last-child  { border-bottom-right-radius: 24px; }
  .panel-item:hover { transform: translateY(-1px); }

  .panel-item::before {
    content: '';
    position: absolute; inset: 0;
    border-radius: inherit;
    opacity: 0; pointer-events: none;
    transition: opacity 0.28s ease;
  }
  .panel-item:hover::before { opacity: 1; }

  .gradient-eu-blue::before { background: var(--gradient-eu-blue); }
  .gradient-eu-blue:hover   { background: rgba(13,45,94,0.10); border-color: rgba(46,104,212,0.45); box-shadow: 0 4px 20px rgba(21,66,139,0.30); }

  .gradient-pink::before { background: var(--gradient-pink); }
  .gradient-pink:hover   { background: rgba(139,16,64,0.10); border-color: rgba(236,93,128,0.45); box-shadow: 0 4px 20px rgba(236,93,128,0.30); }

  .gradient-green::before { background: var(--gradient-primary); }
  .gradient-green:hover   { background: rgba(0,45,48,0.10); border-color: rgba(0,135,146,0.45); box-shadow: 0 4px 20px rgba(0,135,146,0.30); }

  .panel-item .circle {
    position: absolute; right: 0; bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1; border-radius: 50%;
    background: transparent; pointer-events: none;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.26),
      0 0 30px rgba(255,255,255,0.14),
      0 0 60px rgba(255,255,255,0.06),
      inset 0 0 12px rgba(255,255,255,0.05);
    animation: pulsing 5s ease-in-out infinite;
    opacity: 0; transition: opacity var(--transition-base); z-index: 0;
  }
  .panel-item:hover .circle { opacity: 1; }
  .panel-item .circle--lg { width: 180px; animation-delay: 2s; }
  .panel-item .circle--md { width: 120px; animation-delay: 1s; }
  .panel-item .circle--sm { width: 60px;  animation-delay: 0s; }

  .panel-item h4 {
    font-size: 20px; font-weight: 600; letter-spacing: -0.01em;
    color: var(--color-neutral-900);
    position: relative; z-index: 1;
    transition: color var(--transition-fast);
  }
  .panel-item p {
    margin: 0; font-size: 16px; color: var(--color-neutral-500);
    position: relative; z-index: 1;
    transition: color var(--transition-fast);
  }
  .panel-item:hover h4, .panel-item:hover p { color: white; }

  /* ── Hamburger ──────────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px; height: 40px;
    border: none; background: transparent;
    cursor: pointer; padding: 0; border-radius: 50%;
    transition: background 0.15s ease;
  }
  .hamburger:hover { background: rgba(0,0,0,0.06); }

  .bar {
    display: block;
    width: 20px; height: 1.5px;
    background: var(--color-neutral-700);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1), opacity 0.2s ease;
  }

  .nav.mob-open .bar-1 { transform: translateY(6.5px) rotate(45deg); }
  .nav.mob-open .bar-2 { opacity: 0; transform: scaleX(0); }
  .nav.mob-open .bar-3 { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Mobile menu ────────────────────────────────────── */
  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.38s cubic-bezier(0.4,0,0.2,1), opacity 0.22s ease;
  }

  .nav.mob-open .mobile-menu {
    max-height: 700px;
    opacity: 1;
  }

  .mob-inner {
    padding: 6px 12px 16px;
    border-top: 0.5px solid rgba(0,0,0,0.07);
    margin-top: 0;
    display: flex; flex-direction: column; gap: 2px;
  }

  /* Simple link */
  .mob-link {
    display: block;
    padding: 12px 14px;
    border-radius: 14px;
    font-size: 16px; font-weight: 500;
    color: var(--color-neutral-700);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .mob-link:hover { background: rgba(0,0,0,0.05); color: var(--color-neutral-900); }

  /* Group trigger */
  .mob-trigger {
    width: 100%;
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px;
    border-radius: 14px;
    font: inherit; font-size: 16px; font-weight: 500;
    color: var(--color-neutral-700);
    background: transparent; border: none;
    cursor: pointer; text-align: left;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .mob-trigger:hover { background: rgba(0,0,0,0.05); color: var(--color-neutral-900); }

  .mob-chevron {
    display: inline-flex; align-items: center;
    color: var(--color-neutral-400);
    transition: transform 0.25s ease;
  }
  .mob-group.mob-group-open .mob-chevron { transform: rotate(180deg); }

  /* Sub-items container */
  .mob-sub {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
    padding-left: 14px;
  }
  .mob-group.mob-group-open .mob-sub { max-height: 300px; }

  /* Sub-link */
  .mob-sub-link {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .mob-sub-link:hover { background: rgba(0,0,0,0.04); }

  .mob-sub-dot {
    width: 8px; height: 8px; border-radius: 50%;
    flex-shrink: 0; margin-top: 5px;
  }
  .dot-eu-blue  { background: #2e68d4; }
  .dot-pink     { background: #ec5d80; }
  .dot-green    { background: var(--color-primary-600); }
  .dot-none     { background: var(--color-neutral-300); }

  .mob-sub-text { display: flex; flex-direction: column; gap: 1px; }
  .mob-sub-label { font-size: 15px; font-weight: 500; color: var(--color-neutral-800); }
  .mob-sub-desc  { font-size: 12px; color: var(--color-neutral-400); }

  /* CTA */
  .mob-cta-wrap { padding: 10px 14px 2px; }
  .mob-cta { width: 100%; justify-content: center; font-size: 15px !important; }

  /* ── Responsive ─────────────────────────────────────── */
  @media (min-width: 861px) {
    .hamburger    { display: none !important; }
    .mobile-menu  { display: none !important; }
  }

  @media (max-width: 860px) {
    .links        { display: none; }
    .desktop-cta  { display: none; }
    .hamburger    { display: flex; }
  }
</style>

<script>
  function initNav() {
    /* ── Desktop dropdown ─────────────────────────────── */
    const nav     = document.querySelector('[data-nav]') as HTMLElement | null;
    const buttons = document.querySelectorAll<HTMLElement>('[data-menu]');
    const noMenus = document.querySelectorAll('[data-no-menu]');

    const closeDesktop = () => {
      if (!nav) return;
      nav.classList.remove('open');
      nav.removeAttribute('data-active');
      buttons.forEach(b => b.classList.remove('active'));
    };

    buttons.forEach(btn => {
      btn.addEventListener('mouseenter', () => {
        const menu = btn.getAttribute('data-menu');
        if (!menu || !nav) return;
        nav.classList.add('open');
        nav.setAttribute('data-active', menu);
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
      btn.addEventListener('click', () => {
        const menu = btn.getAttribute('data-menu');
        if (!menu || !nav) return;
        if (nav.getAttribute('data-active') === menu) { closeDesktop(); return; }
        nav.classList.add('open');
        nav.setAttribute('data-active', menu);
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });

    nav?.addEventListener('mouseleave', closeDesktop);
    noMenus.forEach(link => link.addEventListener('mouseenter', closeDesktop));
    document.addEventListener('click', e => {
      if (!(e.target instanceof Element)) return;
      if (!e.target.closest('[data-nav]')) closeDesktop();
    });

    /* ── Mobile hamburger ─────────────────────────────── */
    const hamburger  = document.querySelector('[data-hamburger]') as HTMLElement | null;
    const mobileMenu = document.querySelector('[data-mobile-menu]') as HTMLElement | null;

    hamburger?.addEventListener('click', () => {
      const isOpen = nav?.classList.toggle('mob-open');
      hamburger.setAttribute('aria-expanded', String(isOpen));
      if (mobileMenu) mobileMenu.setAttribute('aria-hidden', String(!isOpen));
    });

    /* Close mobile on nav link click */
    mobileMenu?.querySelectorAll('.mob-link, .mob-sub-link, .mob-cta').forEach(link => {
      link.addEventListener('click', () => {
        nav?.classList.remove('mob-open');
        hamburger?.setAttribute('aria-expanded', 'false');
        if (mobileMenu) mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });

    /* ── Mobile group accordions ──────────────────────── */
    document.querySelectorAll<HTMLElement>('[data-mob-trigger]').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const groupEl = trigger.closest('.mob-group') as HTMLElement | null;
        if (!groupEl) return;
        const isOpen = groupEl.classList.toggle('mob-group-open');
        trigger.setAttribute('aria-expanded', String(isOpen));
      });
    });
  }

  document.addEventListener('astro:page-load', initNav);
</script>
