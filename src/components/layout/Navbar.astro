---
import nav from '../../data/nav.yml';
---

<header class="fixed top-5 left-1/2 -translate-x-1/2 w-[min(1200px,calc(100%-20px))] z-[200]">
  <div
    data-nav
    class="nav glass relative flex flex-col rounded-[40px] transition-shadow duration-300"
  >
    <!-- Row principal -->
    <div class="flex items-center justify-between gap-3.5 h-20 pr-5">

      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0 no-underline">
        <img src="/logos/AI4-horizontal-light.svg" alt="AI4EOSC" class="h-20 w-auto" />
      </a>

      <!-- Links centrales -->
      <nav class="links flex gap-0.5 items-center mx-auto" aria-label="Primary">
        {nav.links.map((link) =>
          link.dropdown ? (
            <button
              class="nav-link"
              data-menu={link.label}
              type="button"
            >
              {link.label}
              <span class="chevron" aria-hidden="true">
                <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
          ) : (
            <a class="nav-link" data-no-menu href={link.href}>
              {link.label}
            </a>
          )
        )}
      </nav>

      <!-- CTA -->
      <div class="flex shrink-0">
        <a class="button-pill dark" href={nav.cta.href}>{nav.cta.label}</a>
      </div>
    </div>

    <!-- Panel desplegable -->
    <div data-nav-panel class="nav-panel">
      {nav.links
        .filter((link) => link.dropdown)
        .map((link) => (
          <div
            class="panel"
            data-panel={link.label}
            style={`grid-template-columns: repeat(${link.dropdown?.length ?? 1}, minmax(0, 1fr));`}
          >
            {link.dropdown?.map((item) => (
              <a
                class={`panel-item gradient-${item.hoverGradient ?? 'none'}`}
                href={item.href}
              >
                <span class="circle circle--lg" aria-hidden="true"></span>
                <span class="circle circle--md" aria-hidden="true"></span>
                <span class="circle circle--sm" aria-hidden="true"></span>
                <h4>{item.label}</h4>
                <p>{item.description}</p>
              </a>
            ))}
          </div>
        ))}
    </div>

  </div>
</header>

<style>
  /* ── Sobreescribe el hover de .glass — el nav no hace translateY ── */
  .nav.glass:hover {
    transform: none;
    box-shadow: var(--glass-shadow-neutral);
  }

  .nav.open {
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.12),
      inset 0 0 0 0.5px rgba(255, 255, 255, 0.5);
  }

  /* ── Links ─────────────────────────────────────────────────────── */
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 7px 14px;
    border-radius: 999px;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-neutral-600);
    text-decoration: none;
    background: transparent;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    font-family: var(--font-body);
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .nav-link:hover,
  .nav-link.active {
    background: rgba(0, 0, 0, 0.05);
    color: var(--color-neutral-900);
  }

  /* ── Chevron ───────────────────────────────────────────────────── */
  .chevron {
    display: inline-flex;
    align-items: center;
    color: var(--color-neutral-400);
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      color var(--transition-fast);
  }

  .nav-link.active .chevron {
    transform: rotate(180deg);
    color: var(--color-neutral-700);
  }

  /* ── Panel desplegable ─────────────────────────────────────────── */
  .nav-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height var(--transition-slow),
      opacity 0.2s ease;
  }

  .nav.open .nav-panel {
    max-height: 300px;
    opacity: 1;
  }

  /* Separador */
  .nav.open .nav-panel::before {
    content: '';
    display: block;
    margin: 0 18px;
    height: 0.5px;
    background: rgba(0, 0, 0, 0.07);
  }

  /* ── Grid de panels ────────────────────────────────────────────── */
  .panel {
    display: none;
    gap: 10px;
    padding: 12px 16px 16px;
  }

  .nav[data-active="Ecosystem"] .panel[data-panel="Ecosystem"],
  .nav[data-active="Support"]   .panel[data-panel="Support"] {
    display: grid;
  }

  /* ── Panel items ───────────────────────────────────────────────── */
  .panel-item {
    display: block;
    padding: 10px 10px 10px 20px;
    border-radius: 14px;
    text-decoration: none;
    background: rgba(0, 0, 0, 0.025);
    border: 0.5px solid transparent;
    position: relative;
    overflow: hidden;
    transition:
      background   var(--transition-base),
      border-color var(--transition-base),
      box-shadow   var(--transition-base),
      transform    var(--transition-fast);
  }

  /* Esquinas encajadas: nav radius(40px) − panel padding(16px) = 24px */
  .panel-item:first-child { border-bottom-left-radius:  24px; }
  .panel-item:last-child  { border-bottom-right-radius: 24px; }

  .panel-item:hover { transform: translateY(-1px); }

  /* Capa de gradiente (::before, 0 → 1 en hover) */
  .panel-item::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
  }
  .panel-item:hover::before { opacity: 1; }

  /* EU Blue — Projects */
  .gradient-eu-blue::before { background: var(--gradient-eu-blue); }
  .gradient-eu-blue:hover   {
    background:   rgba(13, 45, 94, 0.10);
    border-color: rgba(46, 104, 212, 0.45);
    box-shadow:   0 4px 20px rgba(21, 66, 139, 0.30);
  }

  /* Pink — Communities / FAQ */
  .gradient-pink::before { background: var(--gradient-pink); }
  .gradient-pink:hover   {
    background:   rgba(139, 16, 64, 0.10);
    border-color: rgba(236, 93, 128, 0.45);
    box-shadow:   0 4px 20px rgba(236, 93, 128, 0.30);
  }

  /* Green — Gateways / Contact */
  .gradient-green::before { background: var(--gradient-primary); }
  .gradient-green:hover   {
    background:   rgba(0, 45, 48, 0.10);
    border-color: rgba(0, 135, 146, 0.45);
    box-shadow:   0 4px 20px rgba(0, 135, 146, 0.30);
  }

  /* ── Círculos pulsantes en panel-items ────────────────────────── */
  .panel-item .circle {
    position: absolute;
    right: 0;
    bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1;
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.26),
      0 0 30px rgba(255, 255, 255, 0.14),
      0 0 60px rgba(255, 255, 255, 0.06),
      inset 0 0 12px rgba(255, 255, 255, 0.05);
    animation: pulsing 5s ease-in-out infinite;
    opacity: 0;
    transition: opacity var(--transition-base);
    z-index: 0;
  }

  .panel-item:hover .circle { opacity: 1; }

  .panel-item .circle--lg { width: 180px; animation-delay: 2s; }
  .panel-item .circle--md { width: 120px; animation-delay: 1s; }
  .panel-item .circle--sm { width: 60px; animation-delay: 0s; }

  @keyframes pulsing {
    0%, 100% { scale: 1; }
    50%       { scale: 1.05; }
  }

  /* ── Tipografía del panel ──────────────────────────────────────── */
  .panel-item h4 {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-neutral-900);
    position: relative;
    z-index: 1;
    transition: color var(--transition-fast);
  }

  .panel-item p {
    margin: 0;
    font-size: 16px;
    color: var(--color-neutral-500);
    position: relative;
    z-index: 1;
    transition: color var(--transition-fast);
  }

  .panel-item:hover h4,
  .panel-item:hover p  { color: white; }

  /* ── Responsive ────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .links { display: none; }
  }
</style>

<script>
  const nav     = document.querySelector('[data-nav]') as HTMLElement | null;
  const buttons = document.querySelectorAll<HTMLElement>('[data-menu]');
  const noMenus = document.querySelectorAll('[data-no-menu]');

  const close = () => {
    if (!nav) return;
    nav.classList.remove('open');
    nav.removeAttribute('data-active');
    buttons.forEach(b => b.classList.remove('active'));
  };

  buttons.forEach(btn => {
    btn.addEventListener('mouseenter', () => {
      const menu = btn.getAttribute('data-menu');
      if (!menu || !nav) return;
      nav.classList.add('open');
      nav.setAttribute('data-active', menu);
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
    btn.addEventListener('click', () => {
      const menu = btn.getAttribute('data-menu');
      if (!menu || !nav) return;
      if (nav.getAttribute('data-active') === menu) { close(); return; }
      nav.classList.add('open');
      nav.setAttribute('data-active', menu);
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  nav?.addEventListener('mouseleave', close);
  noMenus.forEach(link => link.addEventListener('mouseenter', close));
  document.addEventListener('click', e => {
    if (!(e.target instanceof Element)) return;
    if (!e.target.closest('[data-nav]')) close();
  });
</script>
