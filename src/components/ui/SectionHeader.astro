---
interface Props {
  title: string;
  subtitle?: string;
  actionLabel?: string;
  actionHref?: string;
}

const { title, subtitle, actionLabel, actionHref } = Astro.props;
---

<div class="section-header">
  <div>
    <h2>{title}</h2>
    {subtitle && <p>{subtitle}</p>}
  </div>
  {actionLabel && actionHref && (
    <a class="button-pill dark" href={actionHref}>{actionLabel}</a>
  )}
</div>

<style>
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 12px;
  }

  h2 {
    margin: 0;
    font-size: 26px;
    font-weight: 650;
    color: var(--color-neutral-900);
  }

  p {
    margin: 8px 0 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-neutral-500);
    max-width: 460px;
  }

  @media (max-width: 720px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
