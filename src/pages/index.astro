---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Marquee from '../components/sections/Marquee.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import WhoIsItFor from '../components/sections/WhoIsItFor.astro';
import OpenSourceBanner from '../components/sections/OpenSourceBanner.astro';
import ProductsSection from '../components/sections/ProductsSection.astro';
import EcosystemSection from '../components/sections/EcosystemSection.astro';
import NumbersSection from '../components/sections/NumbersSection.astro';
import StoriesSection from '../components/sections/StoriesSection.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CtaFinal from '../components/ui/CtaFinal.astro';
---
<Layout title="AI4EOSC Initiative" description='AI4EOSC is a collaborative initiative to integrate AI into the European Open Science Cloud (EOSC), fostering open science and accelerating research across disciplines.' ogImage="/og/home.png">
  <main>
    <Hero />
    <Marquee />
    <div class="zone-feature">
      <HowItWorks />
      <!-- <WhoIsItFor /> -->
    </div>
    <OpenSourceBanner />
    <ProductsSection />
    <EcosystemSection />
    <div class="zone-impact">
      <NumbersSection />
      <StoriesSection />
      <!-- <Testimonials /> -->
    </div>
    <CtaFinal
      theme="teal"
      title="Ready to build on AI4EOSC?"
      description="Start with a clear, interoperable foundation for research-grade AI services. We can help you design the right deployment path."
      button={{ label: 'Contact the team', href: '/support/contact' }}
    />
  </main>
</Layout>
