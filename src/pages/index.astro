---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Marquee from '../components/sections/Marquee.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import WhoIsItFor from '../components/sections/WhoIsItFor.astro';
import OpenSourceBanner from '../components/sections/OpenSourceBanner.astro';
import ProductsSection from '../components/sections/ProductsSection.astro';
import EcosystemSection from '../components/sections/EcosystemSection.astro';
import CommunitiesSection from '../components/sections/CommunitiesSection.astro';
import GatewaysSection from '../components/sections/GatewaysSection.astro';
import NumbersSection from '../components/sections/NumbersSection.astro';
import StoriesSection from '../components/sections/StoriesSection.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';
---
<Layout title="AI4EOSC Initiative" description='AI4EOSC is a collaborative initiative to integrate AI into the European Open Science Cloud (EOSC), fostering open science and accelerating research across disciplines.'>
  <main>
    <Hero />
    <Marquee />
    <HowItWorks />
    <WhoIsItFor />
    <OpenSourceBanner />
    <ProductsSection />
    <EcosystemSection />
    <CommunitiesSection />
    <GatewaysSection />
    <NumbersSection />
    <StoriesSection />
    <Testimonials />
    <CtaFinal />
  </main>
</Layout>
