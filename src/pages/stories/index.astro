---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import CtaFinal from '../../components/ui/CtaFinal.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { getCollection } from 'astro:content';

const stories = await getCollection('stories');
const sorted = stories.toSorted((a, b) => +b.data.date - +a.data.date);

const types = ['All', ...[...new Set(sorted.map(s => s.data.type))].sort()];

const totalCount = sorted.length;
const newsCount  = sorted.filter(s => s.data.type === 'News').length;
const videoCount = sorted.filter(s => s.data.type === 'Video').length;
---

<Layout title="Stories — AI4EOSC Initiative" ogImage="/og/stories.png">
  <PageHero
    theme="teal"
    breadcrumb="Stories"
    title="Stories from the ecosystem"
    description="Case studies, research highlights and updates from the scientific communities, projects and developers building on AI4EOSC."
  >
    <div class="hero-stats">
      <div class="hstat"><span class="hstat-val">{totalCount}<em>+</em></span><span class="hstat-lbl">Total stories</span></div>
      <div class="hstat"><span class="hstat-val">{newsCount}<em>+</em></span><span class="hstat-lbl">News articles</span></div>
      <div class="hstat"><span class="hstat-val">{videoCount}<em>+</em></span><span class="hstat-lbl">Videos</span></div>
    </div>
  </PageHero>

  <div class="section-label"><div class="container">All stories</div></div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title="From the initiative"
        subtitle="News, case studies and research highlights from across the AI4EOSC ecosystem."
      />

      <div x-data={`{
        filter: 'All',
        page: 1,
        perPage: 9,
        items: [],
        get filtered() {
          return this.items.filter(el => this.filter === 'All' || el.dataset.type === this.filter);
        },
        get totalPages() {
          return Math.max(1, Math.ceil(this.filtered.length / this.perPage));
        },
        get pages() {
          return Array.from({ length: this.totalPages }, (_, i) => i + 1);
        },
        init() {
          this.items = [...this.$el.querySelectorAll('.item')];
          this.$watch('filter', () => { this.page = 1; this.$nextTick(() => this.render()); });
          this.$nextTick(() => this.render());
        },
        setFilter(f) { this.filter = f; },
        goTo(p) {
          this.page = p;
          this.$el.closest('.section-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
          this.$nextTick(() => this.render());
        },
        render() {
          const start = (this.page - 1) * this.perPage;
          const visible = this.filtered.slice(start, start + this.perPage);
          const visibleSet = new Set(visible);
          this.items.forEach(el => {
            el.style.display = visibleSet.has(el) ? '' : 'none';
            el.classList.remove('is-col-sep', 'is-col-end', 'is-row-sep');
          });
          visible.forEach((el, i) => {
            el.classList.toggle('is-col-sep', i % 3 !== 0);
            el.classList.toggle('is-col-end', i % 3 === 2);
            el.classList.toggle('is-row-sep', i >= 3);
          });
        }
      }`}>

        <!-- Filters -->
        <div class="filter-columns">
          <div class="filter-col">
            <span class="filter-col-label">Content type</span>
            <div class="filters">
              {types.map(t => (
                <button
                  class="filter-btn"
                  x-bind:class={`{ 'is-active': filter === '${t}' }`}
                  x-on:click={`setFilter('${t}')`}
                  type="button"
                >
                  {t}
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Grid -->
        <div class="grid">
          {sorted.map((story) => (
            <a
              href={story.data.externalUrl ?? `/stories/${story.id}`}
              class="item has-image"
              data-type={story.data.type}
              style="display:none"
              {...(story.data.externalUrl ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <div class="image">
                {story.data.image
                  ? <img src={story.data.image} alt="" loading="lazy" />
                  : <div class="placeholder" aria-hidden="true">
                      <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.2"/>
                        <path d="M7 8h10M7 12h10M7 16h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                      </svg>
                    </div>
                }
              </div>
              <div class="body">
                <div class="meta">
                  <span class="tag">{story.data.type}</span>
                  <span class="dot" aria-hidden="true"></span>
                  <span class="date">
                    {story.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
                  </span>
                </div>
                <h4>{story.data.title}</h4>
                <p>{story.data.excerpt}</p>
                <span class="read-link">{story.data.externalUrl ? 'View on external site' : 'Read story'}</span>
              </div>
            </a>
          ))}
        </div>

        <!-- Pagination -->
        <div class="pagination" x-show="totalPages > 1" x-cloak>
          <button
            class="page-btn"
            x-on:click="goTo(page - 1)"
            x-bind:disabled="page === 1"
            aria-label="Previous page"
          >←</button>
          <template x-for="p in pages" :key="p">
            <button
              class="page-btn"
              x-bind:class="{ 'is-active': p === page }"
              x-on:click="goTo(p)"
              x-text="p"
            ></button>
          </template>
          <button
            class="page-btn"
            x-on:click="goTo(page + 1)"
            x-bind:disabled="page === totalPages"
            aria-label="Next page"
          >→</button>
        </div>

      </div>
    </div>
  </div>

  <CtaFinal
    theme="teal"
    title="Share your story"
    description="Are you using AI4EOSC in your research? We'd love to feature your work and help others discover what's possible on the platform."
    button={{ label: 'Get in touch', href: '/support/contact' }}
  />
</Layout>


<style>
  /* ── Grid ───────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 20px;
  }

  .item {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
  }

  /* ── Image ──────────────────────────────────────────── */
  .image {
    width: 100%;
    aspect-ratio: 3 / 1;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--card-border);
    background: #1d3238;
  }

  .image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.82;
    filter: grayscale(20%) brightness(0.70);
    transition: opacity 0.45s ease, transform 0.5s ease, filter 0.45s ease;
  }

  .item:hover .image img {
    opacity: 1;
    transform: scale(1.04);
    filter: grayscale(0%) brightness(0.92);
  }

  .placeholder {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 135, 146, 0.22) 1px, transparent 1px);
    background-size: 20px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-icon {
    width: 44px;
    height: 44px;
    color: rgba(0, 135, 146, 0.5);
    transition: color 0.45s ease;
  }

  .item:hover .placeholder-icon {
    color: rgba(0, 135, 146, 0.75);
  }

  /* ── Separators (set by render()) ──────────────────── */
  /*
    Col 1: left 0  / right 28  → 28px total
    Col 2: left 28 / right 28  → 56px total  (+ 1px visual line via background-image)
    Col 3: left 28 / right 0   → 28px total  (+ 1px visual line via background-image)
    All three have equal content width. The separator uses background-image (no layout impact).
  */
  .item.is-col-sep .body {
    padding-left: 28px;
    padding-right: 28px;
    background-image: linear-gradient(to right, var(--card-border) 1px, transparent 1px);
  }

  .item.is-col-end .body {
    padding-left: 28px;
    padding-right: 0;
  }

  .item.is-row-sep {
    border-top: 1px solid var(--card-border);
  }

  /* ── Body ───────────────────────────────────────────── */
  .body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 24px 28px 28px 0;
  }

  /* ── Meta ───────────────────────────────────────────── */
  .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-600);
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-neutral-300);
    flex-shrink: 0;
  }

  .date {
    font-size: 14px;
    color: var(--color-neutral-400);
  }

  h4 {
    margin: 0 0 10px;
    font-family: var(--font-headings);
    font-size: 19px;
    font-weight: 650;
    color: var(--color-neutral-800);
    line-height: 1.3;
    transition: color var(--transition-fast);
  }

  .item:hover h4 { color: var(--color-primary-700); }

  p {
    margin: 0 0 20px;
    font-size: 16px;
    color: var(--color-neutral-500);
    line-height: 1.6;
    flex: 1;
  }

  .read-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary-700);
    margin-top: auto;
    transition: color var(--transition-fast);
  }

  .item:hover .read-link { color: var(--color-primary-600); }
  .read-link::after                         { content: " \2192\FE0E"; }
  .item[target="_blank"] .read-link::after  { content: " \2197\FE0E"; }

  /* ── Pagination ─────────────────────────────────────── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 28px 0 4px;
  }

  .page-btn {
    min-width: 36px;
    height: 36px;
    padding: 0 12px;
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xs);
    background: white;
    color: var(--color-neutral-600);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .page-btn[aria-label] {
    font-size: 18px;
    padding: 0 10px;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--color-primary-300);
    color: var(--color-primary-700);
    background: color-mix(in oklch, var(--color-primary-50) 70%, white);
  }

  .page-btn.is-active {
    background: var(--color-primary-600);
    border-color: var(--color-primary-600);
    color: white;
    font-weight: 600;
  }

  .page-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  /* ── Hero stats ─────────────────────────────────────── */
  .hero-stats { display: flex; gap: 32px; margin-top: 28px; flex-wrap: wrap; }
  .hstat { display: flex; flex-direction: column; gap: 3px; }
  .hstat-val {
    font-family: var(--font-headings); font-size: 40px; font-weight: 600;
    color: #fff; line-height: 1;
  }
  .hstat-val em { font-style: normal; color: rgba(255,255,255,0.45); font-size: 30px; }
  .hstat-lbl { font-size: 18px; color: rgba(255,255,255,0.45); font-weight: 500; }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 860px) {
    .grid { grid-template-columns: 1fr; }
    .item.is-col-sep .body,
    .item.is-col-end .body { padding: 24px 0; background-image: none; }
    .body { padding: 24px 0; }
  }

  @media (max-width: 640px) {
    .hero-stats { gap: 20px; margin-top: 20px; }
    .hstat-val  { font-size: 32px; }
    .hstat-val em { font-size: 22px; }
    .hstat-lbl  { font-size: 14px; }
  }
</style>
