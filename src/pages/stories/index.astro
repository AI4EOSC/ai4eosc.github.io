---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import CtaFinal from '../../components/ui/CtaFinal.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { getCollection } from 'astro:content';

const stories = await getCollection('stories');
const sorted = stories.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const types = ['All', ...Array.from(new Set(sorted.map(s => s.data.type))).sort()];
---

<Layout title="Stories — AI4EOSC Initiative">
  <PageHero
    theme="teal"
    breadcrumb="Stories"
    title="Stories from the ecosystem"
    description="Case studies, research highlights and updates from the scientific communities, projects and developers building on AI4EOSC."
  />

  <div class="section-label"><div class="container">All stories</div></div>
  <div class="container">
    <div class="section-card">
      <SectionHeader
        title="From the initiative"
        subtitle="News, case studies and research highlights from across the AI4EOSC ecosystem."
      />

      <div x-data={`{
        filter: 'All',
        init() {
          this.$watch('filter', () => this.$nextTick(() => this.syncBorders()));
          this.$nextTick(() => this.syncBorders());
        },
        setFilter(f) { this.filter = f; },
        syncBorders() {
          const all = Array.from(this.$el.querySelectorAll('.item'));
          const visible = all.filter(el => el.style.display !== 'none');
          all.forEach(el => el.classList.remove('is-row-start', 'is-new-row'));
          visible.forEach((el, i) => {
            if (i % 3 === 0) el.classList.add('is-row-start');
            if (i >= 3)      el.classList.add('is-new-row');
          });
        }
      }`}>

        <!-- Filters -->
        <div class="filters">
          {types.map(t => (
            <button
              class="filter-btn"
              x-bind:class={`{ 'is-active': filter === '${t}' }`}
              x-on:click={`setFilter('${t}')`}
              type="button"
            >
              {t}
            </button>
          ))}
        </div>

        <!-- Grid -->
        <div class="grid">
          {sorted.map((story) => (
            <a
              href={story.data.externalUrl ?? `/stories/${story.id}`}
              class={`item${story.data.image ? ' has-image' : ''}`}
              x-show={`filter === 'All' || filter === '${story.data.type}'`}
              x-cloak
              {...(story.data.externalUrl ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {story.data.image && (
                <div class="image">
                  <img src={story.data.image} alt="" loading="lazy" />
                </div>
              )}
              <div class="body">
                <div class="meta">
                  <span class="tag">{story.data.type}</span>
                  <span class="dot" aria-hidden="true"></span>
                  <span class="date">
                    {story.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
                  </span>
                </div>
                <h4>{story.data.title}</h4>
                <p>{story.data.excerpt}</p>
                <span class="read-link">{story.data.externalUrl ? 'View on external site ↗' : 'Read story →'}</span>
              </div>
            </a>
          ))}
        </div>

      </div>
    </div>
  </div>

  <CtaFinal
    theme="teal"
    title="Share your story"
    description="Are you using AI4EOSC in your research? We'd love to feature your work and help others discover what's possible on the platform."
    button={{ label: 'Get in touch', href: '/support/contact' }}
  />
</Layout>


<style>
  /* ── Filters ────────────────────────────────────────── */
  .filters {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 20px;
    margin-bottom: 8px;
  }

  .filter-btn {
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.01em;
    border-radius: 999px;
    padding: 6px 16px;
    cursor: pointer;
    border: 1px solid var(--card-border);
    background: white;
    color: var(--color-neutral-500);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .filter-btn:hover:not(.is-active) {
    border-color: var(--color-neutral-300);
    color: var(--color-neutral-700);
    box-shadow: 0 1px 4px rgba(0,0,0,0.07), 0 4px 12px rgba(0,0,0,0.05);
    transform: translateY(-1px);
  }

  .filter-btn.is-active {
    background: var(--color-primary-700);
    color: white;
    border-color: var(--color-primary-700);
    box-shadow: 0 2px 10px color-mix(in oklch, var(--color-primary-600) 40%, transparent);
  }

  /* ── Grid ───────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 24px;
    border-top: 1px solid var(--card-border);
  }

  .item {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
  }

  /* ── Image ──────────────────────────────────────────── */
  .image {
    width: 100%;
    height: 150px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--card-border);
    background:
      radial-gradient(ellipse 60% 55% at 12% 12%, rgba(255, 255, 255, 0.10) 0%, transparent 55%),
      radial-gradient(ellipse 55% 45% at 85% 88%, rgba(0, 20, 24, 0.55) 0%, transparent 58%),
      radial-gradient(ellipse 40% 35% at 55% 48%, rgba(0, 135, 146, 0.18) 0%, transparent 55%),
      linear-gradient(140deg, #001c1e 0%, #004a52 38%, #008792 100%);
  }

  .image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: luminosity;
    opacity: 0.55;
  }

  /* ── Body ───────────────────────────────────────────── */
  .body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 24px 32px 28px 0;
  }

  .item:not(.is-row-start) .body {
    padding-left: 31px;
    border-left: 1px solid var(--card-border);
  }

  .item.is-new-row {
    border-top: 1px solid var(--card-border);
  }

  .item:last-child .body { padding-right: 0; }
  .item:not(.has-image) .body { padding-top: 28px; }

  /* ── Meta ───────────────────────────────────────────── */
  .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-600);
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-neutral-300);
    flex-shrink: 0;
  }

  .date {
    font-size: 14px;
    color: var(--color-neutral-400);
  }

  h4 {
    margin: 0 0 10px;
    font-family: var(--font-headings);
    font-size: 19px;
    font-weight: 650;
    color: var(--color-neutral-800);
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
  }

  .item:hover h4 { color: var(--color-primary-700); }

  p {
    margin: 0 0 20px;
    font-size: 16px;
    color: var(--color-neutral-500);
    line-height: 1.6;
    flex: 1;
  }

  .read-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary-700);
    margin-top: auto;
    transition: color var(--transition-fast);
  }

  .item:hover .read-link { color: var(--color-primary-600); }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      border-top: none;
    }

    .item {
      border-top: 1px solid var(--card-border);
    }

    .body { padding: 24px 0 !important; border-left: none !important; }
  }
</style>
