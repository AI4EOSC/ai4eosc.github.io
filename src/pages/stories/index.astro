---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import CtaFinal from '../../components/sections/CtaFinal.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const stories = await getCollection('stories');
const sorted = stories.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const types = ['All', ...Array.from(new Set(sorted.map(s => s.data.type))).sort()];
---

<Layout title="Stories — AI4EOSC Initiative">
  <PageHero
    theme="teal"
    breadcrumb="Stories"
    title="Stories from the ecosystem"
    description="Case studies, research highlights and updates from the scientific communities, projects and developers building on AI4EOSC."
  />

  <div class="section-label"><div class="container">All stories</div></div>
  <div class="container">
    <div class="section-card" x-data="{
      filter: 'All',
      syncBorders() {
        const all = [...this.$el.querySelectorAll('.item')];
        const vis = all.filter(el => this.filter === 'All' || el.dataset.type === this.filter);
        all.forEach(el => el.classList.remove('is-row-start', 'is-new-row'));
        vis.forEach((el, i) => {
          if (i % 3 === 0) el.classList.add('is-row-start');
          if (i >= 3 && i % 3 === 0) el.classList.add('is-new-row');
        });
      }
    }" x-effect="filter; syncBorders()">
      <SectionHeader
        title="From the initiative"
        subtitle="News, case studies and research highlights from across the AI4EOSC ecosystem."
      />

      <!-- Filters -->
      <div class="filters">
        {types.map(t => (
          <button
            class="filter-btn"
            x-bind:class={`{ 'is-active': filter === '${t}' }`}
            x-on:click={`filter = '${t}'`}
            type="button"
          >
            {t}
          </button>
        ))}
      </div>

      <!-- Grid -->
      <div class="grid">
        {sorted.map((story, i) => (
          <a
            href={story.data.externalUrl ?? `/stories/${story.id}`}
            class={`item${story.data.image ? ' has-image' : ''}`}
            data-type={story.data.type}
            x-show={`filter === 'All' || filter === '${story.data.type}'`}
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 translate-y-2"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-2"
            x-cloak
            {...(story.data.externalUrl ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {story.data.image && (
              <div class="image">
                <img src={story.data.image} alt="" loading="lazy" />
              </div>
            )}
            <div class="body">
              <div class="meta">
                <span class="tag">{story.data.type}</span>
                <span class="dot" aria-hidden="true"></span>
                <span class="date">
                  {story.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
                </span>
              </div>
              <h4>{story.data.title}</h4>
              <p>{story.data.excerpt}</p>
              <span class="read-link">{story.data.externalUrl ? 'View on external site ↗' : 'Read story →'}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <CtaFinal
    theme="teal"
    title="Share your story"
    description="Are you using AI4EOSC in your research? We'd love to feature your work and help others discover what's possible on the platform."
    button={{ label: 'Get in touch', href: '/support/contact' }}
  />
</Layout>

<style>
  /* ── Filters ────────────────────────────────────────── */
  .filters {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }

  .filter-btn {
    font-size: 11px;
    font-weight: 500;
    border-radius: 999px;
    padding: 5px 14px;
    cursor: pointer;
    font: inherit;
    border: 0.5px solid var(--card-border);
    background: var(--page-bg);
    color: var(--color-neutral-500);
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
  }

  .filter-btn:hover:not(.is-active) {
    background: white;
    border-color: var(--color-neutral-300);
  }

  .filter-btn.is-active {
    background: var(--color-neutral-900);
    color: white;
    border-color: var(--color-neutral-900);
  }

  /* ── Grid ───────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 24px;
    border-top: 1px solid var(--card-border);
  }

  .item {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
  }

  /* ── Image ──────────────────────────────────────────── */
  .image {
    width: 100%;
    height: 150px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--card-border);
    background: linear-gradient(135deg, #001a1c 0%, var(--color-primary-800) 60%, var(--color-primary-700) 100%);
  }

  .image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: luminosity;
    opacity: 0.55;
  }

  /* ── Body ───────────────────────────────────────────── */
  .body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 24px 32px 28px 0;
  }

  .item:not(.is-row-start) .body {
    padding-left: 31px;
    border-left: 1px solid var(--card-border);
  }

  /* Row separators — set dynamically by Alpine via .is-row-start */
  .item.is-new-row {
    border-top: 1px solid var(--card-border);
  }

  .item:last-child .body { padding-right: 0; }
  .item:not(.has-image) .body { padding-top: 28px; }

  /* ── Meta ───────────────────────────────────────────── */
  .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-600);
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-neutral-300);
    flex-shrink: 0;
  }

  .date {
    font-size: 13px;
    color: var(--color-neutral-400);
  }

  h4 {
    margin: 0 0 10px;
    font-family: var(--font-headings);
    font-size: 19px;
    font-weight: 650;
    color: var(--color-neutral-800);
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
  }

  .item:hover h4 { color: var(--color-primary-700); }

  p {
    margin: 0 0 20px;
    font-size: 16px;
    color: var(--color-neutral-500);
    line-height: 1.6;
    flex: 1;
  }

  .read-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary-700);
    margin-top: auto;
    transition: color var(--transition-fast);
  }

  .item:hover .read-link { color: var(--color-primary-600); }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      border-top: none;
    }

    .item {
      border-top: 1px solid var(--card-border);
    }

    .item:nth-child(n+4) { border-top: 1px solid var(--card-border); }

    .body { padding: 24px 0 !important; border-left: none !important; }
  }
</style>
