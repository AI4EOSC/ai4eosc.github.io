---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import CtaFinal from '../../components/ui/CtaFinal.astro';
import data from '../../data/projects.yml';

const logoUrls = import.meta.glob<string>(
  '../../assets/logos/*',
  { eager: true, query: '?url', import: 'default' }
);

function formatFunding(amount: number): string {
  if (amount >= 1_000_000_000) {
    const v = amount / 1_000_000_000;
    return `€${Number.isInteger(v) ? v : v.toFixed(1)}B`;
  }
  if (amount >= 1_000_000) {
    const v = amount / 1_000_000;
    return `€${Number.isInteger(v) ? v : v.toFixed(1)}M`;
  }
  if (amount >= 1_000) {
    const v = amount / 1_000;
    return `€${Number.isInteger(v) ? v : v.toFixed(1)}K`;
  }
  return `€${amount}`;
}

const totalProjects = data.items.length;

const allInstitutions = new Set<string>();
data.items.forEach((item: any) => {
  if (item.lead) allInstitutions.add(item.lead.trim());
  if (item.partners) item.partners.forEach((p: string) => allInstitutions.add(p.trim()));
});
const totalInstitutions = allInstitutions.size;
const totalFunding = data.items.reduce((acc: number, item: any) => acc + (item.funding ?? 0), 0);

const typeBadge: Record<string, { label: string; cls: string }> = {
  origin:     { label: 'Origin project',    cls: 'b-origin' },
  associated: { label: 'Associated',         cls: 'b-assoc'  },
  extension:  { label: 'Platform extension', cls: 'b-ext'    },
};

const statusBadge: Record<string, { label: string; cls: string }> = {
  active:   { label: 'Active',   cls: 'b-active' },
  new:      { label: 'New',      cls: 'b-new'    },
  finished: { label: 'Finished', cls: 'b-comp'   },
};
---

<Layout title="Projects — AI4EOSC Ecosystem">
  <PageHero
    theme="blue"
    breadcrumb="Related Projects"
    breadcrumbParent={{ label: 'Ecosystem', href: '/ecosystem/projects' }}
    title="EU-funded projects building the future of open AI"
    description="From the original AI4EOSC project to a growing network of associated initiatives — each extending the platform with new capabilities for the European Open Science Cloud."
  >
    <div class="hero-stats">
      <div class="hstat"><span class="hstat-val">{totalProjects}<em>+</em></span><span class="hstat-lbl">Related projects</span></div>
      <div class="hstat"><span class="hstat-val">{totalInstitutions}<em>+</em></span><span class="hstat-lbl">Involved institutions</span></div>
      <div class="hstat"><span class="hstat-val">{formatFunding(totalFunding)}<em>+</em></span><span class="hstat-lbl">Total EU funding</span></div>
    </div>
  </PageHero>

  <section class="p-section">
    <div class="section-label"><div class="container">All projects</div></div>
    <div class="container">
      <div class="section-card">
        <h2 class="sc-title">Project catalogue</h2>
        <p class="sc-sub">EU-funded projects that originated or extend the AI4EOSC platform. Select any project to see details, partners and links.</p>

        <!--
          Desktop:  sidebar (column, 200px) | detail panel
          Mobile:   sidebar becomes horizontal scroll row, panel below
        -->
        <div class="catalogue" x-data={`{ active: '${data.items[0].id}' }`}>

          <!-- Sidebar / tab strip -->
          <div class="cat-sidebar">
            {data.items.map((item: any) => (
              <button
                class="sidebar-item"
                x-bind:class={`{ 'is-active': active === '${item.id}' }`}
                x-on:click={`active = '${item.id}'`}
                type="button"
              >
                <span class="sc sc--lg" aria-hidden="true"></span>
                <span class="sc sc--md" aria-hidden="true"></span>
                <span class="sc sc--sm" aria-hidden="true"></span>
                <span class="si-name">{item.title}</span>
              </button>
            ))}
          </div>

          <!-- Detail panels -->
          <div class="cat-detail">
            {data.items.map((item: any) => (
              <div class="detail-panel" x-show={`active === '${item.id}'`} x-cloak>
                <div class="detail-inner">

                  <!-- Left: copy -->
                  <div class="pdl">
                    <div class="pdl-top">
                      <span class={`badge ${typeBadge[item.type].cls}`}>{typeBadge[item.type].label}</span>
                      <span class={`badge ${statusBadge[item.status].cls}`}>{statusBadge[item.status].label}</span>
                    </div>
                    <h3>{item.title}</h3>
                    <p class="pdl-tagline">{item.tagline}</p>
                    <p class="pdl-desc">{item.description}</p>

                    <p class="feat-lbl">{item.outputsLabel ?? 'Key outputs'}</p>
                    <ul class="feats">
                      {item.outputs.map((o: string) => (
                        <li class="feat-chip">{o}</li>
                      ))}
                    </ul>

                    {(item.lead || item.partners) && (
                      <div class="partners-meta">
                        <span class="pmeta-lbl">Partners</span>
                        <div class="pchips">
                          {item.lead && (
                            <span class="pchip pchip-lead">{item.lead}</span>
                          )}
                          {item.partners?.map((p: string) => (
                            <span class="pchip">{p}</span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>

                  <!-- Right: logo · meta · actions -->
                  <div class="pdr">

                    {item.logo && logoUrls[`../../assets/logos/${item.logo}`] && (
                      <div class="logo-top">
                        <img src={logoUrls[`../../assets/logos/${item.logo}`]} alt={`${item.title} logo`} class="logo-img" />
                      </div>
                    )}

                    <div class="meta-block">
                      <div class="meta-item">
                        <span class="meta-lbl">Programme</span>
                        <span class="meta-val">{item.programme}</span>
                      </div>
                      {item.grant && (
                        <div class="meta-item">
                          <span class="meta-lbl">Grant</span>
                          <span class="meta-val">{item.grant}</span>
                        </div>
                      )}
                      <div class="meta-item">
                        <span class="meta-lbl">Period</span>
                        <span class="meta-val">{item.period}</span>
                      </div>
                      {item.funding && (
                        <div class="meta-item">
                          <span class="meta-lbl">Funding</span>
                          <span class="meta-val">{formatFunding(item.funding)}</span>
                        </div>
                      )}
                    </div>

                    <div class="pdr-actions">
                      {item.url && (
                        <a class="btn-gray" href={item.url} target="_blank" rel="noopener">Visit project ↗</a>
                      )}
                      {item.cordisUrl && (
                        <a class="btn-outline" href={item.cordisUrl} target="_blank" rel="noopener">CORDIS ↗</a>
                      )}
                    </div>

                  </div>

                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </div>
  </section>

  <CtaFinal
    theme="blue"
    title="Is your project part of the AI4EOSC ecosystem?"
    description="If your EU-funded project uses or extends the AI4EOSC platform, get in touch to be listed here and connect with the community."
    button={{ label: 'Submit your project', href: '/support/contact' }}
  />
</Layout>

<style>
  /* ── Hero stats ─────────────────────────────────────── */
  .hero-stats { display: flex; gap: 32px; margin-top: 28px; flex-wrap: wrap; }
  .hstat { display: flex; flex-direction: column; gap: 3px; }
  .hstat-val {
    font-family: var(--font-headings); font-size: 40px; font-weight: 600;
    color: #fff; letter-spacing: -0.02em; line-height: 1;
  }
  .hstat-val em { font-style: normal; color: rgba(255,255,255,0.45); font-size: 30px; }
  .hstat-lbl { font-size: 18px; color: rgba(255,255,255,0.45); font-weight: 500; }

  /* ── Section layout ─────────────────────────────────── */
  .p-section { padding: 0 0 24px; }

  .sc-title {
    font-family: var(--font-headings);
    font-size: 22px; font-weight: 600; letter-spacing: -0.02em;
    color: var(--color-neutral-900); margin: 0 0 6px;
  }

  .sc-sub {
    font-size: 14px; color: var(--color-neutral-500);
    line-height: 1.6; max-width: 560px; margin: 0;
  }

  /* ── Catalogue layout ───────────────────────────────── */
  .catalogue {
    display: flex;
    gap: 28px;
    align-items: flex-start;
    margin-top: 24px;
  }

  .cat-sidebar {
    flex: 0 0 200px;
    display: flex; flex-direction: column; gap: 6px;
  }

  .cat-detail { flex: 1; min-width: 0; }

  /* ── Sidebar buttons — dark + blue ──────────────────── */
  .sidebar-item {
    width: 100%;
    height: 52px;
    display: flex;
    align-items: center;
    padding: 0 16px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-sm);
    border: none;
    background:
      radial-gradient(ellipse 55% 80% at 5% 50%,  rgba(21, 66, 139, 0.20) 0%, transparent 60%),
      radial-gradient(ellipse 40% 70% at 92% 50%, rgba(60, 100, 220, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 50% 0%,  rgba(255, 255, 255, 0.04) 0%, transparent 50%),
      linear-gradient(140deg, #111418 0%, #1a1f24 50%, #1e2228 100%);
    font: inherit; color: inherit; text-align: left; outline: none;
    transition: box-shadow 0.4s ease;
    flex-shrink: 0;
  }

  .sidebar-item:focus-visible {
    outline: 2px solid rgba(46,104,212,0.5);
    outline-offset: 2px;
  }

  /* Capa activa como pseudo-elemento para poder hacer fade */
  .sidebar-item::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(ellipse 55% 48% at 14% 16%, rgba(255,255,255,0.13) 0%, transparent 55%),
      radial-gradient(ellipse 50% 42% at 82% 86%, rgba(0,5,50,0.5) 0%, transparent 55%),
      var(--gradient-eu-blue);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
  }

  .sidebar-item.is-active::before { opacity: 1; }

  .sidebar-item.is-active {
    box-shadow: 0 4px 24px rgba(46, 104, 212, 0.28);
  }

  /* Decorative circles */
  .sc {
    position: absolute; right: 0; bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1; border-radius: 50%;
    background: transparent; pointer-events: none;
    animation: pulsing 5s ease-in-out infinite;
  }
  .sc--lg { width: 90%; animation-delay: 2s; }
  .sc--md { width: 62%; animation-delay: 1s; }
  .sc--sm { width: 38%; animation-delay: 0s; }

  .sidebar-item .sc {
    box-shadow: 0 0 0 1px rgba(255,255,255,0.08), 0 0 20px rgba(46,104,212,0.15);
    transition: box-shadow 0.4s ease;
  }
  .sidebar-item.is-active .sc { box-shadow: 0 0 0 1px rgba(255,255,255,0.45), 0 0 30px rgba(60,120,220,0.6), 0 0 70px rgba(46,104,212,0.35); }

  .si-name {
    position: relative; z-index: 2;
    font-size: 15px; font-weight: 500; color: white;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* ── Detail panel ───────────────────────────────────── */
  .detail-panel {
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    animation: panelFadeIn 0.22s ease;
  }

  @keyframes panelFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Two columns: content | meta */
  .detail-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    min-height: 380px;
    align-items: stretch;
  }

  /* ── Left: copy ─────────────────────────────────────── */
  .pdl {
    background: var(--page-bg);
    padding: 28px;
    display: flex; flex-direction: column;
  }

  .pdl-top { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }

  .badge {
    font-size: 9px; font-weight: 600; border-radius: 999px; padding: 3px 9px;
  }
  .b-origin { color: #185fa5; background: #e6f1fb; }
  .b-assoc  { color: #3c3489; background: #eeedfe; }
  .b-ext    { color: #0f6e56; background: #e1f5ee; }
  .b-active { color: #059669; background: #f0fdf4; }
  .b-new    { color: #b45309; background: #fffbeb; }
  .b-comp   { color: var(--color-neutral-500); background: var(--color-neutral-100); }

  h3 {
    font-family: var(--font-headings);
    font-size: 28px; font-weight: 600; letter-spacing: -0.03em; line-height: 1.15;
    color: var(--color-neutral-900); margin: 0 0 10px;
  }

  .pdl-tagline {
    font-size: 16px; font-weight: 500; line-height: 1.5;
    color: var(--color-neutral-700); margin: 0 0 14px;
  }

  .pdl-desc {
    font-size: 16px; line-height: 1.7;
    color: var(--color-neutral-500); margin: 0 0 22px;
  }

  .feat-lbl {
    font-size: 10px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--color-neutral-400); margin: 0 0 8px;
  }

  .feats {
    list-style: none; padding: 0; margin: 0 0 18px;
    display: flex; flex-wrap: wrap; gap: 5px;
  }

  .feat-chip {
    font-size: 11px; font-weight: 500; color: var(--color-neutral-700);
    background: white; border: 0.5px solid var(--card-border);
    border-radius: 999px; padding: 3px 10px;
  }

  /* Partners — pills */
  .partners-meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: auto;
    padding-top: 4px;
  }

  .pmeta-lbl {
    font-size: 10px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--color-neutral-400);
  }

  .pchips { display: flex; flex-wrap: wrap; gap: 6px; }

  .pchip {
    font-size: 16px; font-weight: 400;
    color: var(--color-neutral-600);
    background: white; border: 0.5px solid var(--card-border);
    border-radius: 999px; padding: 3px 12px;
  }

  .pchip-lead {
    color: #2e68d4;
    background: rgba(46,104,212,0.07);
    border-color: rgba(46,104,212,0.2);
    font-weight: 600;
  }

  /* ── Right: logo · meta · actions ───────────────────── */
  .pdr {
    background:
      radial-gradient(ellipse 55% 80% at 5% 50%, rgba(21, 66, 139, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 40% 70% at 92% 50%, rgba(60, 100, 220, 0.08) 0%, transparent 60%),
      linear-gradient(140deg, #111418 0%, #1a1f24 50%, #1e2228 100%);
    padding: 24px 20px;
    display: flex; flex-direction: column; gap: 20px;
  }

  /* Logo at top */
  .logo-top {
    background: white;
    border-radius: 8px;
    padding: 10px 14px;
    display: flex; align-items: center; justify-content: center;
  }

  .logo-img {
    max-height: 70px;
    max-width: 100%;
    object-fit: contain;
  }

  .meta-block { display: flex; flex-direction: column; gap: 12px; flex: 1; }

  .meta-item { display: flex; flex-direction: column; gap: 3px; }
  .meta-lbl {
    font-size: 10px; font-weight: 600; letter-spacing: 0.07em;
    text-transform: uppercase; color: rgba(255,255,255,0.35);
  }
  .meta-val { font-size: 13px; color: rgba(255,255,255,0.75); font-weight: 500; }

  /* Buttons in a single row at the bottom */
  .pdr-actions {
    display: flex;
    gap: 8px;
    margin-top: auto;
  }

  /* Visit project — gray bg, turns white on hover */
  .btn-gray {
    flex: 1;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px; padding: 8px 12px;
    font-size: 13px; font-weight: 500; text-decoration: none;
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.85);
    border: 1px solid rgba(255,255,255,0.12);
    transition: background 0.15s, color 0.15s, border-color 0.15s, transform 0.15s;
  }
  .btn-gray:hover {
    background: white;
    color: var(--color-neutral-900);
    border-color: white;
    transform: translateY(-1px);
  }

  /* CORDIS — outline */
  .btn-outline {
    flex: 1;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px; padding: 8px 12px;
    font-size: 13px; font-weight: 500; text-decoration: none;
    background: transparent;
    color: rgba(255,255,255,0.8);
    border: 1px solid rgba(255,255,255,0.22);
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
  }
  .btn-outline:hover {
    background: rgba(255,255,255,0.09);
    border-color: rgba(255,255,255,0.45);
    transform: translateY(-1px);
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 860px) {
    .catalogue { flex-direction: column; }
    .cat-sidebar {
      flex: none; width: 100%;
      flex-direction: row;
      overflow-x: auto;
      scrollbar-width: none;
      padding-bottom: 2px;
      -webkit-overflow-scrolling: touch;
    }
    .cat-sidebar::-webkit-scrollbar { display: none; }
    .sidebar-item {
      flex: 0 0 auto;
      min-width: 140px;
      width: auto;
      height: 52px;
    }
    .cat-detail { width: 100%; }
  }

  @media (max-width: 640px) {
    .detail-inner {
      grid-template-columns: 1fr;
      min-height: unset;
    }
    .pdr { border-top: 0.5px solid var(--card-border); }
  }
</style>
