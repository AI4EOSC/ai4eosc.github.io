---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import CtaFinal from '../../components/ui/CtaFinal.astro';
import data from '../../data/communities.yml';
import gatewaysData from '../../data/gateways.yml';

function formatUsers(count: number): string {
  if (count >= 1_000_000) {
    const v = count / 1_000_000;
    return `${Number.isInteger(v) ? v : v.toFixed(1)}M`;
  }
  if (count >= 1_000) {
    const v = count / 1_000;
    return `${Number.isInteger(v) ? v : v.toFixed(1)}k`;
  }
  return `${count}`;
}

const totalCommunities = data.items.length;
const totalUsers = data.items.reduce((acc: number, item: any) => acc + (item.users ?? 0), 0);
const totalGateways = gatewaysData.items.length;

const icons: Record<string, string> = {
  marine:         `<path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>`,
  climate:        `<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>`,
  bioinformatics: `<path d="M2 3c4 2 6 5 6 9s-2 7-6 9"/><path d="M22 3c-4 2-6 5-6 9s2 7 6 9"/><path d="M6 7h12M6 17h12"/>`,
  social:         `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  humanities:     `<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>`,
  physics:        `<circle cx="12" cy="12" r="1"/><path d="M20.2 20.2c2.04-2.03.02-7.36-4.5-11.9-4.54-4.52-9.87-6.54-11.9-4.5-2.04 2.03-.02 7.36 4.5 11.9 4.54 4.52 9.87 6.54 11.9 4.5z"/><path d="M15.7 15.7c4.52-4.54 6.54-9.87 4.5-11.9-2.03-2.04-7.36-.02-11.9 4.5-4.52 4.54-6.54 9.87-4.5 11.9 2.03 2.04 7.36.02 11.9-4.5z"/>`,
  earth:          `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  astronomy:      `<circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>`,
};

const firstSlug: string = data.items[0]?.slug ?? '';
const communityIds = JSON.stringify(data.items.map((i: any) => i.slug));
---

<Layout title="Communities — AI4EOSC Ecosystem">
  <PageHero
    theme="pink"
    breadcrumb="Communities"
    breadcrumbParent={{ label: 'Ecosystem', href: '/ecosystem/projects' }}
    title="AI tools for every scientific domain"
    description="AI4EOSC brings research-grade AI to a growing number of scientific communities across Europe — from marine biology to climate science and beyond."
  >
    <div class="hero-stats">
      <div class="hstat"><span class="hstat-val">{totalCommunities}<em>+</em></span><span class="hstat-lbl">Active communities</span></div>
      <div class="hstat"><span class="hstat-val">{formatUsers(totalUsers)}<em>+</em></span><span class="hstat-lbl">Researchers served</span></div>
      <div class="hstat"><span class="hstat-val">{totalGateways}<em>+</em></span><span class="hstat-lbl">Gateways deployed</span></div>
    </div>
  </PageHero>

  <!-- ── Communities catalogue ────────────────────────── -->
  <section class="p-section">
    <div class="section-label"><div class="container">All communities</div></div>
    <div class="container">
      <div class="section-card">
        <h2 class="sc-title">Research domains</h2>
        <p class="sc-sub">Select a community to see the AI tools available, related gateways and how to get access.</p>

        <div class="catalogue" x-data={`{
          active: '${firstSlug}',
          ids: ${communityIds},
          init() {
            this.$watch('active', v => history.replaceState(null, '', '#' + v));
            this.$nextTick(() => {
              const hash = window.location.hash.slice(1);
              if (hash && this.ids.includes(hash)) this.active = hash;
            });
          }
        }`}>

          <!-- Sidebar / tab strip -->
          <div class="cat-sidebar">
            {data.items.map((item: any) => (
              <button
                class="sidebar-item"
                x-bind:class={`{ 'is-active': active === '${item.slug}' }`}
                x-on:click={`active = '${item.slug}'`}
                type="button"
              >
                <span class="sc sc--lg" aria-hidden="true"></span>
                <span class="sc sc--md" aria-hidden="true"></span>
                <span class="sc sc--sm" aria-hidden="true"></span>
                <div class="si-inner">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="white" stroke-width="1.75" stroke-linecap="round"
                    stroke-linejoin="round" aria-hidden="true"
                    set:html={icons[item.iconId]} />
                  <span class="si-name">{item.title}</span>
                </div>
              </button>
            ))}
          </div>

          <!-- Detail panels -->
          <div class="cat-detail">
            {data.items.map((item: any) => (
              <div class="detail-panel" x-show={`active === '${item.slug}'`} x-cloak>
                <div class="detail-inner">

                  <!-- Left: content -->
                  <div class="pdl">
                    <div class="pdl-top">
                      {item.via && (
                        <a class="badge b-via" href={`/ecosystem/gateways${item.gatewaySlug ? '#' + item.gatewaySlug : ''}`}>
                          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                          via {item.via}
                        </a>
                      )}
                    </div>
                    <div class="title-row">
                      <span class="title-icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.iconId]} />
                      </span>
                      <h3>{item.title}</h3>
                    </div>
                    <p class="pdl-tagline">{item.description}</p>
                    <p class="pdl-desc">{item.longDescription}</p>

                    {item.tools && (
                      <>
                        <p class="feat-lbl">Available tools</p>
                        <ul class="feats">
                          {item.tools.map((t: string) => (
                            <li class="feat-chip">{t}</li>
                          ))}
                        </ul>
                      </>
                    )}
                  </div>

                  <!-- Right: stats + actions -->
                  <div class="pdr">
                    <div class="meta-block">
                      {item.users && (
                        <div class="meta-item">
                          <span class="meta-lbl">Researchers</span>
                          <span class="meta-val">{formatUsers(item.users)}+</span>
                        </div>
                      )}
                      {item.via && (
                        <div class="meta-item">
                          <span class="meta-lbl">Gateway</span>
                          <span class="meta-val">{item.via}</span>
                        </div>
                      )}
                    </div>

                    <div class="pdr-actions">
                      {item.viaUrl && (
                        <a class="btn-gray" href={item.viaUrl} target="_blank" rel="noopener">
                          Visit gateway ↗
                        </a>
                      )}
                    </div>
                  </div>

                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ── How to join ────────────────────────────────────── -->
  <section class="p-section">
    <div class="section-label"><div class="container">How to join</div></div>
    <div class="container">
      <div class="section-card">
        <h2 class="sc-title">Bring AI4EOSC to your domain</h2>
        <p class="sc-sub">Whether you're a researcher looking for tools or an institution wanting to deploy a community gateway, here's how to get started.</p>
        <div class="how-grid">
          <div class="how-card">
            <div class="step-screen">
              <span class="sc sc--lg" aria-hidden="true"></span>
              <span class="sc sc--md" aria-hidden="true"></span>
              <span class="sc sc--sm" aria-hidden="true"></span>
              <span class="step-num">01</span>
            </div>
            <div class="step-body">
              <h4>Find your domain</h4>
              <p>Browse the communities above to see if your scientific area is already covered and what AI tools are available.</p>
              <a class="step-link" href="#top">Browse communities →</a>
            </div>
          </div>
          <div class="how-card">
            <div class="step-screen">
              <span class="sc sc--lg" aria-hidden="true"></span>
              <span class="sc sc--md" aria-hidden="true"></span>
              <span class="sc sc--sm" aria-hidden="true"></span>
              <span class="step-num">02</span>
            </div>
            <div class="step-body">
              <h4>Access via a gateway</h4>
              <p>Each community has a dedicated gateway — a tailored instance of the platform with domain-specific models and workflows.</p>
              <a class="step-link" href="/ecosystem/gateways">Explore gateways →</a>
            </div>
          </div>
          <div class="how-card">
            <div class="step-screen">
              <span class="sc sc--lg" aria-hidden="true"></span>
              <span class="sc sc--md" aria-hidden="true"></span>
              <span class="sc sc--sm" aria-hidden="true"></span>
              <span class="step-num">03</span>
            </div>
            <div class="step-body">
              <h4>Deploy your own</h4>
              <p>If your domain isn't covered yet, get in touch. We can help you deploy a new community gateway on AI4EOSC.</p>
              <a class="step-link" href="/support/contact">Contact the team →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaFinal
    theme="pink"
    title="Is your scientific domain missing?"
    description="If your research area isn't covered yet, we'd love to hear from you. We can help set up a dedicated community gateway on AI4EOSC."
    button={{ label: 'Get in touch', href: '/support/contact' }}
  />
</Layout>

<style>
  /* ── Hero stats ─────────────────────────────────────── */
  .hero-stats { display: flex; gap: 32px; margin-top: 28px; flex-wrap: wrap; }
  .hstat { display: flex; flex-direction: column; gap: 3px; }
  .hstat-val {
    font-family: var(--font-headings); font-size: 40px; font-weight: 600;
    color: #fff; letter-spacing: -0.02em; line-height: 1;
  }
  .hstat-val em { font-style: normal; color: rgba(255,255,255,0.45); font-size: 30px; }
  .hstat-lbl { font-size: 18px; color: rgba(255,255,255,0.45); font-weight: 500; }

  /* ── Section layout ─────────────────────────────────── */
  .p-section { padding: 0 0 24px; }

  .sc-title {
    font-family: var(--font-headings);
    font-size: 22px; font-weight: 600; letter-spacing: -0.02em;
    color: var(--color-neutral-900); margin: 0 0 6px;
  }
  .sc-sub {
    font-size: 14px; color: var(--color-neutral-500);
    line-height: 1.6; max-width: 560px; margin: 0;
  }

  /* ── Catalogue layout ───────────────────────────────── */
  .catalogue {
    display: flex; gap: 28px; align-items: flex-start; margin-top: 24px;
  }

  .cat-sidebar {
    flex: 0 0 200px;
    display: flex; flex-direction: column; gap: 6px;
  }

  .cat-detail { flex: 1; min-width: 0; }

  /* ── Sidebar buttons — dark + pink ──────────────────── */
  .sidebar-item {
    width: 100%; height: 52px;
    display: flex; align-items: center; padding: 0 16px;
    cursor: pointer; position: relative; overflow: hidden;
    border-radius: var(--radius-sm); border: none;
    background:
      radial-gradient(ellipse 55% 80% at 5% 50%,  rgba(192, 32, 96, 0.18) 0%, transparent 60%),
      radial-gradient(ellipse 40% 70% at 92% 50%, rgba(236, 93, 128, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 50% 0%,  rgba(255, 255, 255, 0.04) 0%, transparent 50%),
      linear-gradient(140deg, #111418 0%, #1a1f24 50%, #1e2228 100%);
    font: inherit; color: inherit; text-align: left; outline: none;
    transition: box-shadow 0.4s ease;
    flex-shrink: 0;
  }

  .sidebar-item:focus-visible { outline: 2px solid rgba(236,93,128,0.5); outline-offset: 2px; }

  /* Active layer via pseudo-element for fade */
  .sidebar-item::before {
    content: '';
    position: absolute; inset: 0; border-radius: inherit;
    background:
      radial-gradient(ellipse 60% 55% at 12% 12%, rgba(255,255,255,0.13) 0%, transparent 55%),
      radial-gradient(ellipse 55% 45% at 85% 88%, rgba(80,10,30,0.45) 0%, transparent 58%),
      var(--gradient-pink);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
  }

  .sidebar-item.is-active::before { opacity: 1; }
  .sidebar-item.is-active { box-shadow: 0 4px 24px rgba(192, 32, 96, 0.3); }

  /* Decorative circles */
  .sc {
    position: absolute; right: 0; bottom: 0;
    transform: translate(50%, 50%);
    aspect-ratio: 1; border-radius: 50%;
    background: transparent; pointer-events: none;
    animation: pulsing 5s ease-in-out infinite;
  }
  .sc--lg { width: 90%; animation-delay: 2s; }
  .sc--md { width: 62%; animation-delay: 1s; }
  .sc--sm { width: 38%; animation-delay: 0s; }

  .sidebar-item .sc {
    box-shadow: 0 0 0 1px rgba(255,255,255,0.08), 0 0 20px rgba(192,32,96,0.12);
    transition: box-shadow 0.4s ease;
  }
  .sidebar-item.is-active .sc {
    box-shadow: 0 0 0 1px rgba(255,255,255,0.45), 0 0 30px rgba(236,93,128,0.65), 0 0 70px rgba(192,32,96,0.35);
  }

  .si-inner {
    position: relative; z-index: 2;
    display: flex; align-items: center; gap: 10px; width: 100%; min-width: 0;
  }

  .si-name {
    font-size: 15px; font-weight: 500; color: white;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* ── Detail panel ───────────────────────────────────── */
  .detail-panel {
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md); overflow: hidden;
    animation: panelFadeIn 0.22s ease;
  }

  @keyframes panelFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .detail-inner {
    display: grid;
    grid-template-columns: 1fr 240px;
    min-height: 340px;
    align-items: stretch;
  }

  /* ── Left: content ──────────────────────────────────── */
  .pdl {
    background: var(--page-bg);
    padding: 28px;
    display: flex; flex-direction: column;
  }

  .pdl-top { margin-bottom: 14px; min-height: 22px; }

  .badge {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 10px; font-weight: 600; border-radius: 999px; padding: 3px 10px;
  }
  .b-via {
    color: #0f6e56;
    background: rgba(26,110,96,0.08);
    border: 0.5px solid rgba(26,110,96,0.22);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .b-via:hover {
    background: rgba(26,110,96,0.15);
    border-color: rgba(26,110,96,0.4);
  }

  .title-row {
    display: flex; align-items: center; gap: 10px; margin: 0 0 10px;
  }

  h3 {
    font-family: var(--font-headings);
    font-size: 28px; font-weight: 600; letter-spacing: -0.03em; line-height: 1.15;
    color: var(--color-neutral-900); margin: 0;
  }

  .title-icon {
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: var(--color-secondary-600);
  }

  .pdl-tagline {
    font-size: 16px; font-weight: 500; line-height: 1.5;
    color: var(--color-neutral-700); margin: 0 0 14px;
  }

  .pdl-desc {
    font-size: 16px; line-height: 1.7;
    color: var(--color-neutral-500); margin: 0 0 24px;
  }

  .feat-lbl {
    font-size: 10px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--color-neutral-400); margin: 0 0 8px;
  }

  .feats {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 6px;
  }

  .feat-chip {
    font-size: 11px; font-weight: 500;
    color: var(--color-secondary-700);
    background: rgba(201,75,114,0.07);
    border: 0.5px solid rgba(201,75,114,0.2);
    border-radius: 999px; padding: 3px 10px;
  }

  /* ── Right: stats + actions ─────────────────────────── */
  .pdr {
    background:
      radial-gradient(ellipse 55% 80% at 5% 50%, rgba(192, 32, 96, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 40% 70% at 92% 50%, rgba(236, 93, 128, 0.08) 0%, transparent 60%),
      linear-gradient(140deg, #111418 0%, #1a1f24 50%, #1e2228 100%);
    padding: 24px 20px;
    display: flex; flex-direction: column; gap: 20px;
  }

  .meta-block { display: flex; flex-direction: column; gap: 16px; flex: 1; }

  .meta-item { display: flex; flex-direction: column; gap: 4px; }
  .meta-lbl {
    font-size: 10px; font-weight: 600; letter-spacing: 0.07em;
    text-transform: uppercase; color: rgba(255,255,255,0.35);
  }
  .meta-val { font-size: 13px; color: rgba(255,255,255,0.75); font-weight: 500; }

  /* Buttons */
  .pdr-actions { display: flex; flex-direction: column; gap: 6px; margin-top: auto; }

  .btn-gray {
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px; padding: 8px 12px;
    font-size: 13px; font-weight: 500; text-decoration: none;
    background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.85);
    border: none;
    transition: background 0.15s, color 0.15s, transform 0.15s;
  }
  .btn-gray:hover { background: white; color: var(--color-neutral-900); transform: translateY(-1px); }

  .btn-outline {
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px; padding: 8px 12px;
    font-size: 13px; font-weight: 500; text-decoration: none;
    background: transparent; color: rgba(255,255,255,0.8);
    border: 1px solid rgba(255,255,255,0.22);
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
  }
  .btn-outline:hover {
    background: rgba(255,255,255,0.09);
    border-color: rgba(255,255,255,0.45);
    transform: translateY(-1px);
  }

  /* ── How to join ────────────────────────────────────── */
  .how-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-top: 24px; }

  .how-card {
    border-radius: var(--radius-md); overflow: hidden;
    border: 0.5px solid var(--card-border); background: var(--card-bg);
  }

  .step-screen {
    position: relative; overflow: hidden;
    padding: 24px 24px 20px; display: flex; align-items: flex-end;
    background:
      radial-gradient(ellipse 60% 55% at 12% 12%, rgba(255,255,255,0.13) 0%, transparent 55%),
      radial-gradient(ellipse 55% 45% at 85% 88%, rgba(80,10,30,0.45) 0%, transparent 58%),
      linear-gradient(140deg, #6b0828 0%, #a01848 38%, #ec5d80 100%);
  }

  /* sc circles inside step-screen use pink glow */
  .step-screen .sc {
    box-shadow: 0 0 0 1px rgba(255,255,255,0.18), 0 0 30px rgba(236,93,128,0.25), 0 0 60px rgba(236,93,128,0.10);
  }

  .step-num {
    font-family: var(--font-headings);
    font-size: 52px; font-weight: 600; letter-spacing: -0.04em; line-height: 1;
    color: rgba(255,255,255,0.9); position: relative; z-index: 2;
  }

  .step-body { padding: 20px 22px 22px; display: flex; flex-direction: column; gap: 8px; }
  .how-card h4 { font-size: 14px; font-weight: 600; color: var(--color-neutral-900); margin: 0; }
  .how-card p  { font-size: 12px; color: var(--color-neutral-500); line-height: 1.65; margin: 0; }
  .step-link { font-size: 12px; font-weight: 500; color: var(--color-secondary-600); text-decoration: none; }
  .step-link:hover { color: var(--color-secondary-700); }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 860px) {
    .catalogue { flex-direction: column; }
    .cat-sidebar {
      flex: none; width: 100%;
      flex-direction: row; overflow-x: auto;
      scrollbar-width: none; padding-bottom: 2px;
      -webkit-overflow-scrolling: touch;
    }
    .cat-sidebar::-webkit-scrollbar { display: none; }
    .sidebar-item { flex: 0 0 auto; min-width: 150px; width: auto; }
    .cat-detail { width: 100%; }
    .how-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .detail-inner { grid-template-columns: 1fr; min-height: unset; }
    .pdr { border-top: 0.5px solid var(--card-border); }
  }
</style>
