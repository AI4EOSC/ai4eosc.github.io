---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import NumbersSection from '../components/sections/NumbersSection.astro';
import CtaFinal from '../components/ui/CtaFinal.astro';
import EuropeMap from '../components/ui/EuropeMap.astro';
import about from '../data/about.yml';
import partners from '../data/partners.yml';
import { getCollection } from 'astro:content';
import euLogo from '../assets/en-v-funded-by-the-eu_black-outline.png';

const logoUrls = import.meta.glob<string>(
  '../assets/logos/*',
  { eager: true, query: '?url', import: 'default' }
);

type PartnerMeta = { name: string; role?: string; logo?: string; url?: string; lat?: number; lon?: number; country?: string; type?: string };
const partnerMeta = new Map((partners.items as PartnerMeta[]).map(p => [p.name, p]));

const projectEntries = await getCollection('projects');
const allNames = new Set<string>();
for (const e of projectEntries) {
  if (e.data.lead) allNames.add(e.data.lead);
  for (const p of e.data.partners ?? []) allNames.add(p);
}

const allPartners = Array.from(allNames)
  .sort((a, b) => a.localeCompare(b))
  .map(name => {
    const m = partnerMeta.get(name);
    const raw = m?.logo ? (logoUrls[`../assets/logos/${m.logo}`] ?? '') : '';
    return { name, role: m?.role ?? 'contributor', src: raw || undefined, url: m?.url, lat: m?.lat, lon: m?.lon, country: m?.country, type: m?.type };
  });

const leaderPartner       = allPartners.find(p => p.role === 'leader');
const corePartners        = allPartners.filter(p => p.role === 'core');
const contributorPartners = allPartners.filter(p => p.role === 'contributor');

const hero = {
  title: 'Building open AI infrastructure for European science',
  description: 'AI4EOSC is an European initiative bringing together a platform, a growing ecosystem of projects, and a network of scientific communities to make research-grade AI accessible across Europe.',
};

const story = {
  label: 'Our story',
  title: 'Where we come from',
  subtitle: 'From a single Horizon Europe grant to a living infrastructure — how AI4EOSC grew from a funded project into an open platform community spanning European science.',
};

const mission = {
  label: 'Mission',
  title: 'What we stand for',
  subtitle: 'AI4EOSC is built on the belief that research-grade AI should be open, interoperable and accessible to any scientific community in Europe.',
  items: [
    { iconId: 'unlock',  title: 'Open by default',         description: 'All software is open source. Models are openly published. Infrastructure is built on open standards. No lock-in, no black boxes.' },
    { iconId: 'link',    title: 'Interoperable with EOSC', description: 'Native integration with EOSC authentication, storage and compute means researchers can start without rebuilding their stack.' },
    { iconId: 'globe',   title: 'Built for European science', description: 'Designed around the needs of European research institutions, following EU values on data sovereignty, ethics and sustainability.' },
    { iconId: 'users',   title: 'Community-driven',        description: 'Shaped by the scientific communities that use it — from marine biologists to climate scientists — and the developers who build on it.' },
  ],
};

const missionIcons: Record<string, string> = {
  unlock: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/>`,
  link:   `<path d="M15 7h3a5 5 0 0 1 5 5 5 5 0 0 1-5 5h-3m-6 0H6a5 5 0 0 1-5-5 5 5 0 0 1 5-5h3"/><line x1="8" y1="12" x2="16" y2="12"/>`,
  globe:  `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  users:  `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
};

const principles = {
  label: 'Principles',
  title: 'How we work',
  subtitle: 'The principles that guide every decision — from architecture to governance.',
  items: [
    { illus: 'commits',  tag: 'Transparency',  title: 'Open development',     description: 'All code, roadmaps and governance decisions are public. We build in the open.' },
    { illus: 'timeline', tag: 'Sustainability', title: 'Long-term thinking',   description: 'Beyond individual project cycles, we build infrastructure that outlasts funding.' },
    { illus: 'access',   tag: 'Inclusivity',   title: 'Low barrier to entry', description: 'Any research community in Europe should be able to join, regardless of technical capacity.' },
  ],
};

const partnersSection = {
  label: 'Partners & institutions',
  title: 'Who\'s behind the initiative',
  subtitle: 'A network of European research institutions, infrastructure providers and cloud partners building together.',
  leaderDesc: 'Spanish National Research Council (CSIC), Spain\'s main public research organisation, coordinates the AI4EOSC initiative through the Advanced Computing and e-Science Group at the Instituto de Física de Cantabria (IFCA-CSIC-UC), driving platform development and governance across the European Open Science Cloud.',
  contributorDesc: 'Research institutions, infrastructure providers and industry partners from across Europe contributing to the AI4EOSC ecosystem through the associated projects.',
};

const funding = {
  title: 'Funded by Horizon Europe',
  description: 'The original <strong>AI4EOSC project</strong> was funded by the European Union under the Horizon Europe research and innovation programme. Associated projects within the initiative are independently funded through their own EU grants.',
  link: { label: 'Explore all projects in the ecosystem', href: '/ecosystem/projects' },
  badge: { title: 'Horizon Europe', grant: 'No. 101058593' },
};

const cta = {
  title: 'Join the AI4EOSC community',
  description: 'Whether you\'re a researcher, developer or institution, there\'s a place for you in the ecosystem. Start by exploring what the platform can do for you.',
  button: { label: 'Explore the platform', href: '/products' },
};
---

<Layout
  title="About — AI4EOSC Initiative"
  description={hero.description}
  ogImage="/og/about.png"
>
  <main>

    <!-- PAGE HERO -->
    <PageHero
      theme="teal"
      breadcrumb="About"
      title={hero.title}
      description={hero.description}
    />

    <!-- OUR STORY -->
    <div class="section-label"><div class="container">{story.label}</div></div>
    <div class="container">
      <div class="section-card">
        <SectionHeader title={story.title} subtitle={story.subtitle} />
        <div class="timeline">
          {about.timeline.map((item, i) => {
            const isLast = i === about.timeline.length - 1;
            return (
              <div class={`tl-item reveal${isLast ? ' tl-last' : ''}`} style={`transition-delay:${i * 80}ms`}>
                <div class="tl-meta">
                  <span class="tl-year">{item.year}</span>
                  {item.phase && <span class="tl-phase">{item.phase}</span>}
                </div>
                <div class="tl-spine" aria-hidden="true">
                  <span class="tl-dot"></span>
                  <span class="tl-line"></span>
                </div>
                <div class="tl-body">
                  <div class="tl-content">
                    <div class="tl-head">
                      <h4>{item.title}</h4>
                      {isLast && <span class="tl-pill">Ongoing</span>}
                    </div>
                    <p>{item.description}</p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <!-- EU FUNDING -->
    <div class="container eu-wrap">
      <div class="eu-card reveal">
        <div class="eu-circles" aria-hidden="true">
          <span class="circle circle--lg"></span>
          <span class="circle circle--md"></span>
          <span class="circle circle--sm"></span>
        </div>
        <div class="eu-left">
          <h3>{funding.title}</h3>
          <p set:html={funding.description} />
          <a href={funding.link.href} class="eu-link">{funding.link.label}</a>
        </div>
        <div class="eu-badge">
          <img class="eu-flag" src={euLogo.src} alt="Co-funded by the European Union" />
          <strong>{funding.badge.title}</strong>
          <p>Grant agreement<br/>{funding.badge.grant}</p>
        </div>
      </div>
    </div>

    <!-- MISSION -->
    <div class="section-label"><div class="container">{mission.label}</div></div>
    <div class="container">
      <div class="section-card">
        <SectionHeader title={mission.title} subtitle={mission.subtitle} />
        <div class="mission-grid">
          {mission.items.map((item, i) => (
            <div class="mission-item reveal" style={`transition-delay:${i * 70}ms`}>
              <div class="mission-icon-wrap">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={missionIcons[item.iconId]}
                />
              </div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- PRINCIPLES -->
    <div class="section-label"><div class="container">{principles.label}</div></div>
    <div class="container">
      <div class="section-card">
        <SectionHeader title={principles.title} subtitle={principles.subtitle} />
        <div class="principles-grid">
          {principles.items.map((item, i) => (
            <div class="principle-item reveal" style={`transition-delay:${i * 80}ms`}>

              <div class="principle-render">

                {/* ── Transparency: public commit log ── */}
                {item.illus === 'commits' && (
                  <div class="p-win">
                    <div class="p-chrome">
                      <span class="p-dot p-dot--r"></span>
                      <span class="p-dot p-dot--y"></span>
                      <span class="p-dot p-dot--g"></span>
                      <span class="p-wlabel">ai4eosc/platform</span>
                      <span class="p-pub">PUBLIC</span>
                    </div>
                    <div class="p-commits">
                      <div class="p-commit">
                        <span class="p-cnode"></span>
                        <div class="p-cinfo">
                          <span class="p-cmsg">Updated governance policy</span>
                          <span class="p-cmeta">@jlaurent · 2h ago · #283</span>
                        </div>
                      </div>
                      <div class="p-commit">
                        <span class="p-cnode"></span>
                        <div class="p-cinfo">
                          <span class="p-cmsg">Published Q2 roadmap</span>
                          <span class="p-cmeta">@ai4eosc · 1d ago · #282</span>
                        </div>
                      </div>
                      <div class="p-commit p-commit--dim">
                        <span class="p-cnode"></span>
                        <div class="p-cinfo">
                          <span class="p-cmsg">Enable public audit log</span>
                          <span class="p-cmeta">@mrodriguez · 3d ago · #281</span>
                        </div>
                      </div>
                    </div>
                    <div class="p-foot">
                      <span class="p-foot-stat">247 contributors</span>
                      <span class="p-sep">·</span>
                      <span>All changes public</span>
                    </div>
                  </div>
                )}

                {/* ── Sustainability: project lifecycle bars ── */}
                {item.illus === 'timeline' && (
                  <div class="p-win">
                    <div class="p-chrome">
                      <span class="p-dot p-dot--r"></span>
                      <span class="p-dot p-dot--y"></span>
                      <span class="p-dot p-dot--g"></span>
                      <span class="p-wlabel">project lifecycle</span>
                    </div>
                    <div class="p-lifecycle">
                      <div class="p-lrow">
                        <span class="p-llabel">AI4EOSC</span>
                        <div class="p-lbar"><div class="p-lfill" style="width:100%"></div></div>
                        <span class="p-lstatus p-done">Done</span>
                      </div>
                      <div class="p-lrow">
                        <span class="p-llabel">iMagine</span>
                        <div class="p-lbar"><div class="p-lfill" style="width:100%"></div></div>
                        <span class="p-lstatus p-done">Done</span>
                      </div>
                      <div class="p-lrow p-lrow--active">
                        <span class="p-llabel">Initiative</span>
                        <div class="p-lbar"><div class="p-lfill p-lfill--live" style="width:62%"></div></div>
                        <span class="p-lstatus p-live">Live</span>
                      </div>
                    </div>
                    <div class="p-foot p-axis-foot">
                      <span class="p-timeline-axis">2022</span>
                      <div class="p-axis-line"></div>
                      <span class="p-timeline-axis">2026 →</span>
                    </div>
                  </div>
                )}

                {/* ── Inclusivity: access checklist ── */}
                {item.illus === 'access' && (
                  <div class="p-win">
                    <div class="p-chrome">
                      <span class="p-dot p-dot--r"></span>
                      <span class="p-dot p-dot--y"></span>
                      <span class="p-dot p-dot--g"></span>
                      <span class="p-wlabel">getting started</span>
                    </div>
                    <div class="p-checklist">
                      <div class="p-check">
                        <span class="p-checkmark">✓</span>
                        <span class="p-checklabel">EOSC institutional account</span>
                      </div>
                      <div class="p-check">
                        <span class="p-checkmark">✓</span>
                        <span class="p-checklabel">Free for EU researchers</span>
                      </div>
                      <div class="p-check">
                        <span class="p-checkmark">✓</span>
                        <span class="p-checklabel">Any scientific domain</span>
                      </div>
                      <div class="p-check">
                        <span class="p-checkmark">✓</span>
                        <span class="p-checklabel">No compute setup needed</span>
                      </div>
                    </div>
                    <div class="p-foot">
                      <span class="p-access-btn">Get access →</span>
                    </div>
                  </div>
                )}

              </div>

              <div class="principle-body">
                <span class="principle-label">{item.tag}</span>
                <h4>{item.title}</h4>
                <p>{item.description}</p>
              </div>

            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- NUMBERS -->
    <NumbersSection />

    <!-- PARTNERS -->
    <div class="section-label"><div class="container">{partnersSection.label}</div></div>
    <div class="container">
      <div class="section-card">
        <SectionHeader title={partnersSection.title} subtitle={partnersSection.subtitle} />
        <EuropeMap partners={allPartners} />

        <!-- Leader -->
        <div class="tier-leader">
          <div class="tier-leader-text">
            <span class="tier-heading">AI4EOSC Initiative is led by</span>
            <p class="tier-desc">{partnersSection.leaderDesc}</p>
          </div>
          {leaderPartner?.src && (
            <div class="leader-right">
              <a class="leader-logo-link" href={leaderPartner.url} target="_blank" rel="noopener noreferrer" aria-label={leaderPartner.name}>
                <img src={leaderPartner.src} alt={leaderPartner.name} class="leader-logo-img" loading="lazy" />
              </a>
              <div class="leader-attr">
                <span>Instituto de Física de Cantabria</span>
                <span>Advanced Computing and e-Science Group</span>
                <span>Santander, Spain</span>
              </div>
            </div>
          )}
        </div>

        <!-- Core Partners -->
        <div class="tier-block">
          <span class="tier-heading">Core Partners</span>
          <p class="tier-desc">The founding research institutions, infrastructure providers and technology companies that built and operate the AI4EOSC platform.</p>
          <div class="partners-grid">
            {corePartners.map((partner) => (
              partner.src ? (
                <a href={partner.url || undefined} target={partner.url ? '_blank' : undefined} rel={partner.url ? 'noopener noreferrer' : undefined} class="partner-card" aria-label={partner.name}>
                  <img src={partner.src} alt={partner.name} class="partner-logo" loading="lazy" />
                </a>
              ) : (
                <div class="partner-card partner-text" title={partner.name}>
                  <span class="partner-name">{partner.name}</span>
                </div>
              )
            ))}
          </div>
        </div>

        <!-- Contributors -->
        <div class="tier-block">
          <span class="tier-heading">Contributors</span>
          <p class="tier-desc">{partnersSection.contributorDesc}</p>
          <div class="partners-grid">
            {contributorPartners.map((partner) => (
              partner.src ? (
                <a href={partner.url || undefined} target={partner.url ? '_blank' : undefined} rel={partner.url ? 'noopener noreferrer' : undefined} class="partner-card" aria-label={partner.name}>
                  <img src={partner.src} alt={partner.name} class="partner-logo" loading="lazy" />
                </a>
              ) : (
                <div class="partner-card partner-text" title={partner.name}>
                  <span class="partner-name">{partner.name}</span>
                </div>
              )
            ))}
          </div>
        </div>

      </div>
    </div>

    <CtaFinal
      theme="teal"
      title={cta.title}
      description={cta.description}
      button={cta.button}
    />

  </main>
</Layout>

<style>
  /* ── TIMELINE ─────────────────────────────────────── */
  .timeline {
    display: flex;
    flex-direction: column;
    margin-top: 36px;
    border-top: 1px solid var(--card-border);
  }

  .tl-item {
    display: grid;
    grid-template-columns: 116px 52px 1fr;
    align-items: stretch;
  }

  /* ── Left: year + phase ── */
  .tl-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    padding-top: 32px;
    padding-right: 2px;
  }

  .tl-year {
    font-family: var(--font-headings);
    font-size: 24px;
    font-weight: 700;
    color: var(--color-primary-500);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .tl-last .tl-year { color: var(--color-primary-600); }

  .tl-phase {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-neutral-300);
    text-align: right;
    line-height: 1.2;
  }

  /* ── Center: spine ── */
  .tl-spine {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 39px;
  }

  .tl-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: white;
    border: 2px solid var(--color-primary-400);
    flex-shrink: 0;
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--color-primary-300) 14%, transparent);
    transition: border-color var(--transition-fast);
    position: relative; z-index: 1;
  }

  .tl-item:hover .tl-dot { border-color: var(--color-primary-500); }

  .tl-last .tl-dot {
    background: var(--color-primary-500);
    border-color: var(--color-primary-500);
    box-shadow:
      0 0 0 4px color-mix(in oklch, var(--color-primary-400) 20%, transparent),
      0 0 10px color-mix(in oklch, var(--color-primary-500) 30%, transparent);
    animation: pulsing 2.8s ease-in-out infinite;
  }

  .tl-line {
    flex: 1;
    width: 1.5px;
    background: linear-gradient(to bottom, var(--color-primary-200) 0%, transparent 100%);
    margin-top: 8px;
  }

  .tl-last .tl-line { display: none; }

  /* ── Right: body wrapper ── */
  .tl-body { padding-left: 20px; min-width: 0; }

  /* Row with separator */
  .tl-content {
    padding: 32px 0 36px;
    border-bottom: 1px solid var(--card-border);
  }

  .tl-last .tl-content { border-bottom: none; padding-bottom: 12px; }

  /* ── Head ── */
  .tl-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .tl-head h4 {
    font-family: var(--font-headings);
    font-size: 19px;
    font-weight: 650;
    color: var(--color-neutral-900);
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .tl-last .tl-head h4 { color: var(--color-primary-700); }

  .tl-pill {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-primary-600);
    background: color-mix(in oklch, var(--color-primary-100) 65%, white 35%);
    border-radius: 999px;
    padding: 3px 10px;
    flex-shrink: 0;
    line-height: 1;
  }

  .tl-text p {
    font-size: 16px;
    color: var(--color-neutral-500);
    line-height: 1.8;
    margin: 0;
  }

  .tl-last .tl-text p { color: var(--color-neutral-600); }


  /* ── MISSION ──────────────────────────────────────── */
  .mission-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    margin-top: 32px;
    border-top: 1px solid var(--card-border);
  }

  .mission-item {
    padding: 32px 40px 36px 0;
    position: relative;
  }

  .mission-item:nth-child(odd) {
    border-right: 1px solid var(--card-border);
  }

  .mission-item:nth-child(even) {
    padding-right: 0;
    padding-left: 40px;
  }

  .mission-item:nth-child(n+3) {
    border-top: 1px solid var(--card-border);
  }

  .mission-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-100);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary-600);
    margin-bottom: 20px;
    flex-shrink: 0;
  }

  .mission-item h3 {
    font-family: var(--font-headings);
    font-size: 19px;
    font-weight: 650;
    color: var(--color-neutral-900);
    margin: 0 0 10px;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }

  .mission-item p {
    font-size: 15px;
    color: var(--color-neutral-500);
    line-height: 1.75;
    margin: 0;
  }

  /* ── PRINCIPLES ───────────────────────────────────── */
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 32px;
    border-top: 1px solid var(--card-border);
  }

  .principle-item {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .principle-item:not(:last-child) { border-right: 1px solid var(--card-border); }

  /* ── Render area ── */
  .principle-render {
    height: 196px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--card-border);
    flex-shrink: 0;
    background: var(--color-primary-50);
    overflow: hidden;
  }

  /* ── Shared window shell ── */
  .p-win {
    background: #1e2233;
    border-radius: 10px;
    width: calc(100% - 32px);
    height: 162px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.18);
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease;
  }

  .principle-item:hover .p-win { transform: translateY(-4px); }

  .p-chrome {
    background: #2a2f42;
    padding: 7px 10px;
    display: flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
  }

  .p-dot {
    width: 8px; height: 8px;
    border-radius: 50%; flex-shrink: 0;
  }
  .p-dot--r { background: #ff5f57; }
  .p-dot--y { background: #febc2e; }
  .p-dot--g { background: #28c840; }

  .p-wlabel {
    font-size: 10px; color: #6b7280;
