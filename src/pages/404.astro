---
import Layout from '../layouts/Layout.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';
---

<Layout
  title="404 | AI4EOSC Initiative"
  description="The page you are looking for does not exist."
>
   <section class="flex flex-col items-center justify-center min-h-screen -mt-18 pt-32 pb-25 md:pt-60 overflow-hidden">
      <div class="container-custom slide-up text-center my-auto">
        <h1 class="text-9xl font-bold text-primary-600 dark:text-primary-400 mb-2">404</h1>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">Page Not Found</h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">
          The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
        </p>
        <div class="flex justify-center gap-4 flex-wrap">
          <a href="/" class="btn-primary">
            Return Home
          </a>
          <a href="/contact" class="btn-secondary">
            Contact Support
          </a>
        </div>
      </div>

      <div class="container-custom slide-up text-center mt-auto pb-16">
        <!-- Espacio reservado para equilibrar el centrado -->
      </div>
    </section>
    <CtaFinal />
</Layout>
