---
import Layout from '../layouts/Layout.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';
---

<Layout
  title="404 | AI4EOSC Initiative"
  description="The page you are looking for does not exist."
>
  <section class="not-found">
    <div class="container">
      <div class="content">
        <span class="code">404</span>
        <h1>Page not found</h1>
        <p>The page you're looking for might have been removed, had its name changed, or is temporarily unavailable.</p>
        <div class="actions">
          <a href="/" class="button-pill dark">Return home</a>
          <a href="/support/contact" class="btn-outline">Contact support</a>
        </div>
      </div>
    </div>
  </section>
  <CtaFinal
    theme="teal"
    title="Ready to build on AI4EOSC?"
    description="Start with a clear, interoperable foundation for research-grade AI services. We can help you design the right deployment path."
    button={{ label: 'Contact the team', href: '/support/contact' }}
  />
</Layout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    min-height: 80svh;
    padding: calc(var(--nav-offset) + 40px) 0 80px;
  }

  .content {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .code {
    display: block;
    font-family: var(--font-headings);
    font-size: clamp(96px, 16vw, 168px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(160deg, #003c40 0%, #008792 55%, #00c8d8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    margin-bottom: 12px;
  }

  h1 {
    font-family: var(--font-headings);
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-neutral-900);
    margin: 0 0 14px;
  }

  p {
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-neutral-500);
    margin: 0 0 36px;
  }

  .actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 10px 22px;
    border: 1px solid var(--card-border);
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-neutral-700);
    background: var(--card-bg);
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-base),
      border-color var(--transition-fast);
  }

  .btn-outline:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-1);
    border-color: var(--color-neutral-300);
  }
</style>
